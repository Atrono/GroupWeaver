<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GroupWeaver.App.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <!-- Design tokens (#91): spacing scale + structural-neutral card chrome + the
         mono name-stack. In Application.Resources so the type-scale StaticResource
         references (FontFamilyMono) and the Button.ghost border below resolve. -->
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Styles/Tokens.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <!-- Type scale (#91): the chrome FOUNDATION, AFTER FluentTheme so its class
         setters layer over the Fluent defaults. -->
    <StyleInclude Source="/Styles/Typography.axaml" />

    <!-- Hyperlink-styled button (WebView2 banner / GraphHost placeholder, AP 2.1 S7):
         Fluent has no hyperlink control, so a flat button without hover chrome. -->
    <Style Selector="Button.hyperlink">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="2,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Foreground" Value="#0F6CBD" />
    </Style>
    <Style Selector="Button.hyperlink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#0A4E8A" />
    </Style>

    <!-- Secondary "ghost" button (#91 foundation; #93 consumes it): transparent with
         the structural card border, so a button can read as secondary against a card
         without a palette fill. -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <!-- ADR-026 D3 (WP1a): the pointer-over wash flips with the variant — Dark #14FFFFFF /
         Light #0D000000 — via the theme-resolved GhostHoverBrush (DynamicResource so it
         re-resolves on a live ThemeVariant change). -->
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
    </Style>

    <!-- Primary "accent" button (ADR-026 D6, WP2): the brand purple, replacing FluentTheme's
         default-blue accent class on the primary actions that carry Classes="accent" (Connect,
         Settings Save). WCAG: WHITE text on the AccentFill ramp clears 4.5:1 at every interactive
         state (rest 5.02:1 / hover 5.97:1 / pressed 6.39:1 dark; 6.12 / 7.58 / 8.20 light) —
         the ramp goes DARKER on hover/pressed, never lighter (auto-lightening would fall
         below 4.5:1). DynamicResource so it re-resolves on a live ThemeVariant flip. The base
         Setters target the control (rest); the :pointerover/:pressed states target the Fluent
         template's PART_ContentPresenter (the same seam Button.ghost uses). -->
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource AccentFillBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentFillBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentFillHoverBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentFillPressedBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <!-- Accent-OUTLINE button (WP3, #152): a distinct third tier between the grey ghosts and the
         filled-accent primary — an accent hairline border + accent INK label/glyph, hollow at rest,
         with a subtle accent-soft wash on hover. Promotes the Audit button (the health-verdict
         destination) without cloning the filled Refresh accent (the ui-checklist's action-hierarchy
         ambiguity guard). The ink is AccentTextBrush (the accessible deepened accent — the decorative
         AccentBrush FAILS as text); the border reuses that same opaque AccentTextBrush so the outline
         is deterministically >=3:1 in both themes (not the translucent AccentLineBrush, which could
         flatten below the non-text floor); the hover wash is AccentSoftBrush. All DynamicResource so
         they re-resolve on a live ThemeVariant flip. -->
    <Style Selector="Button.accent-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentTextBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    </Style>
    <Style Selector="Button.accent-outline /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    </Style>
    <Style Selector="Button.accent-outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentTextBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    </Style>
    <Style Selector="Button.accent-outline:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentTextBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    </Style>

    <!-- ADR-033: app-wide KEYBOARD-focus-visible ring on the native chrome (WCAG 2.4.7 / 2.4.11).
         The ring REPLACES each control's default Fluent focus visual with a custom accent FocusAdorner:
         a 2px {DynamicResource AccentTextBrush} Border (dark #A99BFF / light #4A3CC8 — >=3:1 non-text on
         both card and page in both themes, ADR-021/026), transparent fill, drawn EDGE-HUGGING (Margin=0)
         so it hugs the control's own outline. The FocusAdorner shows via the AdornerLayer, which DOES
         composite in the headless Skia capture (the default Fluent FocusAdorner composites there too —
         its WHITE-in-dark / dark ring, and the ComboBox's solid blue, visually dominated an earlier
         BoxShadow attempt; REPLACING the whole FocusAdorner is what makes the accent the dominant
         indicator). Margin=0 (not a negative outward margin) is deliberate: a control with
         ClipToBounds=true — ComboBox does — clips an OUTWARD adorner away (only a corner speck survived),
         but an edge-hugging one is never clipped. Shown ONLY on keyboard/programmatic focus (the
         :focus-visible-gated FocusAdorner; never on a pointer press) — keyboard-only by construction. No
         fill change, no animation. DynamicResource brush re-resolves on a live ThemeVariant flip. The
         Border CornerRadius matches each control's own radius (so the radius-12 chip ring rounds too —
         its chip/segment-specific radius parity lives in AuditView.axaml). The segment/chip filter
         controls are Buttons with bound Classes, so the Button rule covers them. -->
    <Style Selector="Button:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="4" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>
    <Style Selector="ToggleButton:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="4" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>
    <Style Selector="CheckBox:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="4" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBoxItem:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="4" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>
    <!-- Selected-item band → the brand accent (ADR-026 D6), replacing FluentTheme's default-BLUE
         SystemAccentColor selection fill on genuine ListBox.SelectedItem lists (the root picker).
         Uses the theme-aware translucent-accent AccentSoftBrush (dark #298B7BFF / light #1F6A5CFF —
         the same decorative-accent selection/focus role documented in BrandTokens / Tokens.axaml),
         so a selected row reads as a subtle brand-purple band in both themes. Selection BEHAVIOUR is
         unchanged — only the fill hue. DynamicResource re-resolves on a live ThemeVariant flip;
         :selected:pointerover keeps the band on hover-over-selected (Fluent would otherwise flip it
         back to its own accent-tinted hover fill). -->
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <!-- ComboBox: the accent FocusAdorner ring AND a keyboard-focus suppression of Fluent's solid blue
         focus highlight (Border#HighlightBackground turns opaque #0078D7 on focus, which would fill the
         box and mask the accent). Neutralizing it only under :focus-visible keeps the accent dominant on
         keyboard focus while leaving pointer interaction untouched. -->
    <Style Selector="ComboBox:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="4" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>
    <Style Selector="ComboBox:focus-visible /template/ Border#HighlightBackground">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </Application.Styles>

</Application>

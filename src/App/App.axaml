<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GroupWeaver.App.App"
             RequestedThemeVariant="Default">

  <Application.Styles>
    <FluentTheme />

    <!-- Hyperlink-styled button (WebView2 banner / GraphHost placeholder, AP 2.1 S7):
         Fluent has no hyperlink control, so a flat button without hover chrome. -->
    <Style Selector="Button.hyperlink">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="2,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Foreground" Value="#0F6CBD" />
    </Style>
    <Style Selector="Button.hyperlink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#0A4E8A" />
    </Style>
  </Application.Styles>

</Application>

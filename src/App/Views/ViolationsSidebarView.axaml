<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GroupWeaver.App.ViewModels"
             xmlns:views="using:GroupWeaver.App.Views"
             x:Class="GroupWeaver.App.Views.ViolationsSidebarView"
             x:DataType="vm:WorkspaceViewModel">

  <UserControl.Styles>
    <!-- #197 severity filter chip: matches the Audit screen's chip visual (AuditView.axaml) using the
         SAME tokens/affordance, kept LOCAL so AuditView's screenshot-pinned rendering stays byte-
         identical (its chip styles are inline in its own UserControl.Styles, not a shared resource).
         The INACTIVE chip is a ghost pill (transparent fill, card border, secondary ink); the ACTIVE
         chip (Classes.chip-active, bound to AuditFilterChip.IsActive) swaps to an OPAQUE raised fill +
         strong ink + a 2px border — a redundant border/fill/ink change, NEVER hue alone (WCAG 1.4.1),
         >=4.5:1 in both themes via the ChipActive* tokens. The app-wide Button:focus-visible ring
         (App.axaml) covers keyboard focus. -->
    <Style Selector="Button.chip">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
    </Style>
    <Style Selector="Button.chip-active">
      <Setter Property="Background" Value="{DynamicResource ChipActiveBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChipActiveForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SecondaryForegroundBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <!-- The chip count digits at FULL opacity (tabular numerals), inheriting the chip's foreground so
         the digit contrast matches the label (WCAG 1.4.3). -->
    <Style Selector="TextBlock.chip-count">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="FontFeatures" Value="tnum=1" />
    </Style>
  </UserControl.Styles>

  <!-- Violations sidebar (AP 3.4 S4, ADR-010 §5): tops the right column ABOVE the
       AP 2.5 detail stack (the 2*,Auto,3* vertical split, beside GraphHost, never
       over it - ADR-001 airspace guardrail 5). Binds the workspace VM's report
       projection: the canonical-report-order ViolationRowModel rows (S5 fills the
       projection), the all-clear state, and the "unexpanded areas are unchecked"
       hint. Severity is NOT a detail-panel attribute (ADR-007) - it lives here and
       on the graph halos, reading THE one SeverityConverters palette so the sidebar
       glyph color matches the overlay-color the bundle paints. -->
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12,12,12,8">

    <!-- Header (AP 4.1 / ADR-013 §6): "Findings (n)" left, the report-export pair right.
         n = TotalViolationCount (the UNFILTERED total; #197 — the severity chips below filter
         the list, so the header must reflect the whole report, never shrinking as chips filter).
         The two-column split keeps the title/chips clear of the export buttons - the buttons
         NEVER crowd the chip strip below (Row 1). Each button is disabled until a load completes:
         CanExportReport gates on Snapshot is not null (F2 - the unchecked-areas appendix is
         exportable in the all-clear state), so the pre-load state shows the buttons greyed. -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0"
                 Text="{Binding TotalViolationCount, StringFormat='Findings ({0})'}"
                 Classes="subheading"
                 VerticalAlignment="Center" />
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
        <Button Name="ExportCsvButton" Content="Export CSV"
                Padding="8,4" FontSize="12"
                ToolTip.Tip="Export findings as CSV"
                Command="{Binding ExportReportCsvCommand}" />
        <Button Name="ExportHtmlButton" Content="Export HTML"
                Padding="8,4" FontSize="12"
                ToolTip.Tip="Export findings as a self-contained HTML file"
                Command="{Binding ExportReportHtmlCommand}" />
      </StackPanel>
    </Grid>

    <!-- Per-severity filter chips (#197): each an E/W/i glyph square in THE one
         SeverityConverters palette (overlay-color parity with the graph halos) + a label +
         its count over the UNFILTERED report. They top the sidebar so all THREE severity
         glyphs (with redundant E/W/i letters) are visible above the scroll fold, AND each is
         now a clickable toggle FILTER (ToggleSeverityFilterCommand): clicking narrows the
         list below to that severity (multi-select, fail-open — no active chip = all findings).
         The active chip carries a redundant non-hue affordance (opaque fill + strong ink +
         2px border via Classes.chip-active, bound to AuditFilterChip.IsActive) so the active
         state is not color-only (WCAG 1.4.1). The whole strip hides in the all-clear state
         (HasViolations), so no chips show with no findings. The strip stays in Row 1, OUTSIDE
         the findings ListBox's bottom-fade mask (ShellScreenshotTests geometry pin). -->
    <ItemsControl Grid.Row="1" Margin="0,6,0,0"
                  ItemsSource="{Binding SeverityChips}"
                  IsVisible="{Binding HasViolations}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:AuditFilterChip">
          <Button Classes="chip" Margin="0,0,6,0"
                  Classes.chip-active="{Binding IsActive}"
                  Command="{Binding $parent[views:ViolationsSidebarView].((vm:WorkspaceViewModel)DataContext).ToggleSeverityFilterCommand}"
                  CommandParameter="{Binding}"
                  ToolTip.Tip="Toggle this severity filter">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Border Width="16" Height="16" CornerRadius="3" VerticalAlignment="Center"
                      Background="{Binding Severity, Converter={x:Static views:SeverityConverters.ToBrush}}">
                <TextBlock Text="{Binding Severity, Converter={x:Static views:SeverityConverters.ToGlyph}}"
                           Foreground="{Binding Severity, Converter={x:Static views:SeverityConverters.ToTextBrush}}"
                           FontSize="10" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Count}" Classes="chip-count" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- The findings list (canonical report order, unshuffled - ADR-009). Each row:
         severity glyph (colored square + redundant letter from THE one palette),
         wrapping message, dimmed subject name; the whole row is a flat command
         button jumping to (focusing + selecting) the finding's anchor DN. -->
    <!-- Soft bottom fade (#92): the shared ListBottomFadeMask (Tokens.axaml) so a finding
         clipped at the scroll fold reads as scrollable, not broken. Render-only composite -
         it does NOT alter row measurement/realization or the Row 1 chip strip (outside the
         mask), so the ShellScreenshotTests geometry pins hold. -->
    <ListBox Grid.Row="2" Margin="0,8,0,0"
             Background="Transparent"
             OpacityMask="{StaticResource ListBottomFadeMask}"
             ItemsSource="{Binding Violations}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:ViolationRowModel">
          <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Padding="4" BorderThickness="0"
                  Background="{Binding IsActive, Converter={x:Static views:SelectionHighlightConverters.IsActiveToBackground}}"
                  ToolTip.Tip="{Binding PrimaryDn}"
                  Command="{Binding $parent[views:ViolationsSidebarView].((vm:WorkspaceViewModel)DataContext).JumpCommand}"
                  CommandParameter="{Binding PrimaryDn}">
            <Grid ColumnDefinitions="Auto,*">

              <!-- Severity glyph: colored square (overlay-color parity) + redundant
                   letter E/W/i - the colorblind-safe channel beside the color. -->
              <Border Grid.Column="0" Width="20" Height="20" CornerRadius="3"
                      VerticalAlignment="Top"
                      Background="{Binding Severity, Converter={x:Static views:SeverityConverters.ToBrush}}">
                <TextBlock Text="{Binding Severity, Converter={x:Static views:SeverityConverters.ToGlyph}}"
                           Foreground="{Binding Severity, Converter={x:Static views:SeverityConverters.ToTextBrush}}"
                           FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>

              <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SubjectName}" FontSize="11" Opacity="0.6"
                           TextWrapping="Wrap" />
              </StackPanel>

            </Grid>
          </Button>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- All-clear: shown only when there are no findings. The unchecked hint below
         still fires if areas remain unchecked (clean != fully checked). -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0"
               Text="No findings."
               IsVisible="{Binding !HasViolations}"
               Opacity="0.7" TextWrapping="Wrap"
               VerticalAlignment="Top" />

    <!-- "Unexpanded areas are unchecked" hint (PLANNING.md AP 3.4): visible whenever
         UncheckedDns is non-empty - a load-state honesty notice, never ignore-filtered
         (ADR-009), shown even in the all-clear state. Wrapped in a tinted info block
         (#92 chrome#10) on the #91 card tokens so it reads as a distinct affordance,
         not body copy; the info glyph is plain text (no sized Border) to stay clear of
         the 18x18/20x20 geometry pins. -->
    <Border Grid.Row="3" Margin="0,8,0,0"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1" CornerRadius="6" Padding="8,6"
            IsVisible="{Binding HasUncheckedAreas}">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0" Text="&#x2139;" Classes="secondary"
                   VerticalAlignment="Top" Margin="0,0,8,0" />
        <TextBlock Grid.Column="1"
                   Text="Unexpanded areas are unchecked — expand groups to audit them."
                   Classes="secondary" TextWrapping="Wrap" />
      </Grid>
    </Border>

  </Grid>

</UserControl>

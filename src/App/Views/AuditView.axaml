<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GroupWeaver.App.ViewModels"
             xmlns:views="using:GroupWeaver.App.Views"
             x:Class="GroupWeaver.App.Views.AuditView"
             x:DataType="vm:AuditViewModel">

  <UserControl.Styles>
    <!-- WP5d segmented Table | Graph control: two flush buttons reading as one pill. The active
         segment carries the card-tint fill + a stronger border; the inactive is ghost. -->
    <Style Selector="Button.segment">
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.segment-active">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SecondaryForegroundBrush}" />
    </Style>
    <!-- ADR-033 corner-radius parity: the segment is a square (radius 0) flush button, so its
         keyboard-focus accent FocusAdorner (App.axaml) is re-set here with a SQUARE ring (radius 0),
         overriding the App-wide radius-4 default so the ring matches the segment's own corners.
         Edge-hugging (Margin=0), as App.axaml — never clipped. -->
    <Style Selector="Button.segment:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="0" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>

    <!-- WP1 filter chip: a flat, ghost toggle Button (NOT a ToggleButton — avoids double-toggle). The
         INACTIVE chip is a ghost pill (transparent fill, card border, secondary ink); the ACTIVE chip
         (Classes.chip-active, bound to AuditFilterChip.IsActive) swaps to the card-tint fill + a
         stronger secondary border — a redundant border/fill change, NEVER hue alone (WCAG 1.4.1). -->
    <Style Selector="Button.chip">
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
    </Style>
    <!-- Active (selected) chip: an OPAQUE raised fill + a strong near-primary ink + the 2px border —
         a redundant border/fill/ink change (never hue alone). The opaque fill avoids the translucent
         card-tint composite that dropped the active count to 4.44:1 in light; both the label and the
         count now clear 4.5:1 with wide headroom in BOTH themes (11.78:1 light / 10.39:1 dark). -->
    <Style Selector="Button.chip-active">
      <Setter Property="Background" Value="{DynamicResource ChipActiveBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChipActiveForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SecondaryForegroundBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <!-- ADR-033 corner-radius parity: the chip is a radius-12 pill, so its keyboard-focus accent
         FocusAdorner (App.axaml) is re-set here with a matching radius-12 rounded ring, overriding the
         App-wide radius-4 default so the ring rides the pill's own corners. Edge-hugging (Margin=0), as
         App.axaml — never clipped, and the Border CornerRadius rounds the ring (resolving the earlier
         square-corner limitation on the radius-12 chip). -->
    <Style Selector="Button.chip:focus-visible">
      <Setter Property="FocusAdorner">
        <FocusAdornerTemplate>
          <Border BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="2"
                  CornerRadius="12" Margin="0" />
        </FocusAdornerTemplate>
      </Setter>
    </Style>
    <!-- WP1 chip count: tabular numerals at FULL opacity (NOT Classes="dn", whose 0.8 opacity drops
         the meaningful count below 4.5:1 in light; WCAG 1.4.3). Inherits the chip's foreground (the
         same full-opacity ink the chip label uses) so the digit contrast matches the label. -->
    <Style Selector="TextBlock.chip-count">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="FontFeatures" Value="tnum=1" />
    </Style>

    <!-- WP5d sortable column header: a flat, ghost button hosting the eyebrow label + caret. -->
    <Style Selector="Button.colhead">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <!-- Audit step (WP5 / #152): the audit dashboard. WP5c (#154) fleshes the WP5b placeholder out
       into the real health band — a band-coded health RING + a four-tile count row across the top,
       a categories pane below. It owns NO graph renderer (no GraphHost airspace region, unlike
       Workspace/Plan/Gap). The findings TABLE is WP5d; bulk triage + status filters are WP5e.
       Theme-aware via DynamicResource tokens (both variants); all text >= 4.5:1 on the card surface
       in both themes (the colored accents/dots are the non-text channel, WCAG 1.4.1). -->
  <Border Padding="24" Background="{DynamicResource PageBackgroundBrush}">
    <!-- The audit screen stacks a lot of fixed-height content (header + ring/tiles + categories card +
         filter strip + table + actions) — more than fits 720px. Rather than fight the vertical budget,
         the WHOLE page scrolls: when content exceeds the viewport the page scrolls and the action bar +
         table stay reachable (never overlapped). All outer rows are therefore Auto (a * row collapses
         to nothing inside a ScrollViewer's unbounded height); the findings ListBox caps its own height
         + scrolls internally for long lists. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <!-- Outer rows: 0 header / 1 ring+tiles / 2 categories pane / 3 WP1 filter-strip toolbar
         (full width) / 4 table+detail split (Auto — the ListBox caps + scrolls) / 5 run-history
         compare card (ADR-032 / #190) / 6 actions.
         The 16px right margin reserves a GUTTER for the Auto vertical scrollbar so it never overlays
         the rightmost edge content (the 4th count tile clipped at 1280px). The gutter is constant —
         it does not over-inset at wider widths since it only reserves the scrollbar's fixed width. -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,16,0">

      <!-- 1. Header: "Audit · {RootDn}". -->
      <TextBlock Grid.Row="0" Text="{Binding Title}" Classes="heading" />

      <!-- 2. Health band: the score RING (left) + the four count tiles (right). -->
      <Grid Grid.Row="1" Margin="0,16,0,0" ColumnDefinitions="Auto,*" ColumnSpacing="16">

        <!-- Health ring card. The ring is a ConicGradientBrush filled to RingFraction (= Score/100)
             with a band-coded hue; the inner disc punches the card surface back through, leaving a
             donut. The meaning is the always-present "{Score} / 100" + band TEXT (WCAG 1.4.1 — the
             ring colour is a redundant emphasis cue, never the sole channel). The whole control
             carries an AutomationProperties.Name restating score + band for screen readers. -->
        <Border Grid.Column="0" Padding="20" VerticalAlignment="Top"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                AutomationProperties.Name="{Binding HealthAutomationName}">
          <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">

            <!-- The ring: a 96x96 conic-filled disc with a 70x70 inner disc cut back to the card
                 surface; the score/band text sits on the inner disc. Two stop pairs share the
                 RingFraction offset to give a hard fill edge (band hue 0..frac, track frac..1). -->
            <Panel Width="96" Height="96">
              <Ellipse Width="96" Height="96">
                <Ellipse.Fill>
                  <ConicGradientBrush>
                    <GradientStop Offset="0"
                                  Color="{Binding Band, Converter={x:Static views:SeverityConverters.BandToRingColor}}" />
                    <GradientStop Offset="{Binding RingFraction}"
                                  Color="{Binding Band, Converter={x:Static views:SeverityConverters.BandToRingColor}}" />
                    <GradientStop Offset="{Binding RingFraction}" Color="#33808080" />
                    <GradientStop Offset="1" Color="#33808080" />
                  </ConicGradientBrush>
                </Ellipse.Fill>
              </Ellipse>
              <!-- Inner disc: paints the card surface back over the ring centre (donut hole) and
                   hosts the score text. -->
              <Border Width="70" Height="70" CornerRadius="35"
                      Background="{DynamicResource CardBackgroundBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="-2">
                <TextBlock Name="ScoreText" Text="{Binding Score}"
                           FontSize="26" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="/ 100" Classes="caption"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Panel>

            <StackPanel VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="Directory health" Classes="eyebrow" />
              <TextBlock Name="BandText" Text="{Binding Band}"
                         FontSize="22" FontWeight="SemiBold" />

              <!-- Triage caveat (ADR-030 D2 / #188), gated on HasTriaged: the SAME honest treatment as
                   the Unchecked caveat below — a tinted bordered block with a plain-text info glyph — so
                   the headline discloses that the clean number excludes N acknowledged/suppressed
                   findings. The band word stays the headline above; this qualifier travels with it. -->
              <Border Margin="0,8,0,0" MaxWidth="240"
                      Background="{DynamicResource CardBackgroundBrush}"
                      BorderBrush="{DynamicResource CardBorderBrush}"
                      BorderThickness="1" CornerRadius="6" Padding="8,6"
                      IsVisible="{Binding HasTriaged}">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Grid.Column="0" Text="&#x2139;" Classes="secondary"
                             VerticalAlignment="Top" Margin="0,0,8,0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding TriageCaveatText}"
                             Classes="secondary" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- Four count tiles. Each: the big count + a label + a colored accent (left-border + dot)
             from the severity palette. The count + label use the NORMAL card foreground (theme
             default / SecondaryForegroundBrush) on the card surface — both clear 4.5:1 in BOTH
             themes; the colour lives only in the accent border/dot (the non-text channel). -->
        <UniformGrid Grid.Column="1" Columns="4" VerticalAlignment="Top">

          <!-- Critical (Error red). -->
          <Border Margin="0,0,12,0" Padding="14,12"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{x:Static views:BrandTokens.Error}"
                  BorderThickness="3,0,0,0" CornerRadius="{StaticResource CardCornerRadius}">
            <StackPanel Spacing="3">
              <TextBlock Name="CriticalCount" Text="{Binding Critical}"
                         FontSize="26" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{x:Static views:BrandTokens.Error}" />
                <TextBlock Text="Critical" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Warnings (Warning amber) + an Info sub-affordance (muted chip). -->
          <Border Margin="0,0,12,0" Padding="14,12"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{x:Static views:BrandTokens.Warning}"
                  BorderThickness="3,0,0,0" CornerRadius="{StaticResource CardCornerRadius}">
            <StackPanel Spacing="3">
              <TextBlock Name="WarningsCount" Text="{Binding Warnings}"
                         FontSize="26" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{x:Static views:BrandTokens.Warning}" />
                <TextBlock Text="Warnings" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
              </StackPanel>
              <!-- Info as a muted sub-count on the Warnings tile (honest: Info is not part of
                   Critical/Warnings — it is the lowest severity). -->
              <TextBlock Name="InfoSub" Classes="caption"
                         Text="{Binding Info, StringFormat='+ {0} info'}" />
            </StackPanel>
          </Border>

          <!-- Passing (success green — NamingOk, deliberately outside the severity palette). -->
          <Border Margin="0,0,12,0" Padding="14,12"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{x:Static views:BrandTokens.NamingOk}"
                  BorderThickness="3,0,0,0" CornerRadius="{StaticResource CardCornerRadius}">
            <StackPanel Spacing="3">
              <TextBlock Name="PassingCount" Text="{Binding Passing}"
                         FontSize="26" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{x:Static views:BrandTokens.NamingOk}" />
                <TextBlock Text="Passing" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Rule classes (neutral — the card-border colour, no severity hue). -->
          <Border Padding="14,12"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{DynamicResource CardBorderBrush}"
                  BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}">
            <StackPanel Spacing="3">
              <TextBlock Name="RuleClassesCount" Text="{Binding RuleClasses}"
                         FontSize="26" FontWeight="Bold" />
              <TextBlock Text="Rule classes" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource SecondaryForegroundBrush}" />
            </StackPanel>
          </Border>

        </UniformGrid>
      </Grid>

      <!-- 3. Categories pane: the rule classes that produced findings (canonical rule order),
           each a row of dot + class name + count. Each row IS the rule-class filter facet
           (WP-C/#180) — clicking it toggles the findings filter to that class (the separate strip
           RULE CLASS chip group was removed as a duplicate). The unchecked caveat sits below the
           list inside the same card. -->
      <Border Grid.Row="2" Margin="0,16,0,0" Padding="16"
              Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
              VerticalAlignment="Top">
        <Grid RowDefinitions="Auto,Auto,Auto">

          <TextBlock Grid.Row="0" Text="Rule classes · click to filter" Classes="eyebrow" Margin="0,0,0,8" />

          <!-- The category rows. Each is a flat, full-width, left-aligned filter Button: a max-severity
               dot (colour, non-text channel) + the class display name + its count. The active (selected)
               row reuses the chip-active visual (opaque fill + strong ink + 2px border — a redundant
               border/fill/ink change, never hue alone; WCAG 1.4.1) via Classes.chip-active bound to
               IsActive. The name + count clear 4.5:1 on the card surface in both themes. -->
          <ItemsControl Grid.Row="1" Name="CategoriesList"
                        ItemsSource="{Binding Categories}"
                        IsVisible="{Binding HasCategories}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:AuditCategoryRow">
                <Button Classes="chip" CornerRadius="6" Padding="8,4" Margin="0,0,0,2"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Classes.chip-active="{Binding IsActive}"
                        Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).ToggleCategoryCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="Filter the findings to this rule class">
                  <Grid ColumnDefinitions="Auto,*,Auto" Height="24">
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Margin="2,0,10,0"
                             Fill="{Binding MaxSeverity, Converter={x:Static views:SeverityConverters.ToBrush}}" />
                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="Normal"
                               HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="2" Text="{Binding Count}" Classes="chip-count"
                               VerticalAlignment="Center" />
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- All-clear: no class produced a finding. -->
          <TextBlock Grid.Row="1" Text="No findings."
                     IsVisible="{Binding !HasCategories}"
                     Classes="secondary" TextWrapping="Wrap" />

          <!-- Unchecked caveat (gated on UncheckedPresent): the SAME honest treatment as the rail —
               a tinted info block with a plain-text info glyph — so the score never implies a clean
               bill over unexpanded subtrees. -->
          <Border Grid.Row="2" Margin="0,12,0,0"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{DynamicResource CardBorderBrush}"
                  BorderThickness="1" CornerRadius="6" Padding="8,6"
                  IsVisible="{Binding UncheckedPresent}">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Grid.Column="0" Text="&#x2139;" Classes="secondary"
                         VerticalAlignment="Top" Margin="0,0,8,0" />
              <TextBlock Grid.Column="1"
                         Text="Unexpanded areas are unchecked — the score covers checked objects only."
                         Classes="secondary" TextWrapping="Wrap" />
            </Grid>
          </Border>

        </Grid>
      </Border>

      <!-- 4. WP1 filter chip strip: its OWN full-width toolbar row (between the categories pane and
           the table+detail split) so it reflows within ~1240px — NOT crammed into the findings card's
           narrow left column where it wrapped tall and overlapped the action bar. Reads as a toolbar,
           not a card: a borderless padded WrapPanel. Two multi-select chip facets (Severity / Status)
           that AND together — an EMPTY axis imposes no constraint; the rule-class facet is the
           categories pane above (WP-C/#180). Each chip is a flat
           Button (not a ToggleButton — avoids double-toggle); its active visual is a redundant
           border + opaque fill + ink change (Classes.chip-active bound to IsActive), never hue alone.
           Every group's eyebrow label AND its chips ItemsControl are DIRECT wrap items, so each chip
           reflows against the full row width. The chip-count digits are full-opacity ink (NOT
           Classes="dn", whose 0.8 opacity drops the meaningful count below 4.5:1; WCAG 1.4.3). -->
      <WrapPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0"
                 IsVisible="{Binding !IsAllClear}">

        <!-- Severity group. The chip shows a colored severity glyph square (E/W/i) + the label +
             count — the colour is a redundant cue beside the letter (WCAG 1.4.1). -->
        <TextBlock Text="SEVERITY" Classes="eyebrow" VerticalAlignment="Center" Margin="0,0,4,6" />
        <ItemsControl ItemsSource="{Binding SeverityChips}" Margin="0,0,12,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AuditFilterChip">
              <Button Classes="chip" Margin="0,0,4,6"
                      Classes.chip-active="{Binding IsActive}"
                      Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).ToggleFilterCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="Toggle this severity filter">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Border Width="16" Height="16" CornerRadius="3" VerticalAlignment="Center"
                          Background="{Binding Severity, Converter={x:Static views:SeverityConverters.ToBrush}}">
                    <TextBlock Text="{Binding Severity, Converter={x:Static views:SeverityConverters.ToGlyph}}"
                               Foreground="{Binding Severity, Converter={x:Static views:SeverityConverters.ToTextBrush}}"
                               FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Count}" Classes="chip-count" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Status group (Open / Acknowledged / Suppressed). Label + count; no severity glyph. -->
        <TextBlock Text="STATUS" Classes="eyebrow" VerticalAlignment="Center" Margin="0,0,4,6" />
        <ItemsControl ItemsSource="{Binding StatusChips}" Margin="0,0,12,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AuditFilterChip">
              <Button Classes="chip" Margin="0,0,4,6"
                      Classes.chip-active="{Binding IsActive}"
                      Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).ToggleFilterCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="Toggle this status filter">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Count}" Classes="chip-count" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- The rule-class facet lives on the categories pane above (WP-C/#180) — clicking a category
             row toggles the rule-class filter; this strip carries only the Severity + Status axes. -->

        <!-- Clear filters + the "Showing N of M" summary (each a direct wrap item so they reflow
             tidily onto the strip rather than orphaning on a detached line). -->
        <Button Name="ClearFiltersButton" Content="Clear filters"
                Classes="chip" Padding="10,4" Margin="0,0,8,6"
                IsVisible="{Binding IsFiltered}"
                Command="{Binding ClearFiltersCommand}"
                ToolTip.Tip="Clear all active findings filters" />
        <TextBlock Name="FilterSummaryText" Text="{Binding FilterSummary}"
                   Classes="secondary" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,6" />

      </WrapPanel>

      <!-- 5. Findings table region (WP5d / #156): a Table | Graph segmented toggle + a multi-select
           selection bar over a pure-Avalonia (no DataGrid) findings table. The table is a header
           Grid + a ListBox whose row template shares the SAME ColumnDefinitions string as the header
           (one shared definition => header/body columns align without a DataGrid). "Graph" routes to
           ShowInGraphCommand (v1 has no in-audit renderer); "Table" is the always-active in-audit
           pane (pressed style). Theme-aware via DynamicResource; severity colour is the redundant
           glyph+colour channel (SeverityConverters), all text >= 4.5:1 on the card surface both themes. -->
      <!-- Two-pane split (WP5f / #160): the findings TABLE card on the left, the selected finding's
           DETAIL pane on the right. The detail is driven by the table's ListBox SelectedItem (the
           single ACTIVE finding) — DISTINCT from the multi-select triage checkboxes. -->
      <Grid Grid.Row="4" Margin="0,16,0,0" ColumnDefinitions="*,Auto" ColumnSpacing="16">

      <Border Grid.Column="0" Padding="16"
              Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}">
        <!-- The findings sub-row is Auto (not *): a * row collapses inside the page ScrollViewer's
             unbounded height. The ListBox caps its own height (MaxHeight) + scrolls internally; the
             empty-state TextBlocks carry a MinHeight so they render even when the list is empty. -->
        <Grid RowDefinitions="Auto,Auto,Auto,Auto">

          <!-- Table | Graph segmented toggle. Table = the active in-audit pane (pressed). Graph =
               an action that returns to the workspace graph (no in-audit renderer in v1). The WP1
               filter chip strip is NOT here — it has its own full-width row above this card. -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="0" HorizontalAlignment="Left">
            <Button Name="TableSegment" Content="Table"
                    Classes="segment segment-active"
                    ToolTip.Tip="Findings table (this view)" />
            <Button Name="GraphSegment" Content="Graph"
                    Classes="segment"
                    ToolTip.Tip="Return to the graph view of the explored structure"
                    Command="{Binding ShowInGraphCommand}" />
          </StackPanel>

          <!-- Selection bar (WP5d + WP5e triage): "{n} selected" + the real Acknowledge / Suppress /
               Un-triage actions + Clear. Acknowledge/Suppress append an equal-strength tagged global-
               ignore entry (ADR-028) so the finding drops from the live report (health up, graph/rail
               quiet) but stays listed here as reversible; Un-triage removes the entry, reopening it.
               Visible only when >= 1 finding is selected. -->
          <Border Grid.Row="1" Margin="0,12,0,0" Padding="10,6"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{DynamicResource CardBorderBrush}"
                  BorderThickness="1" CornerRadius="6"
                  IsVisible="{Binding HasSelection}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} selected'}"
                         FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                         Margin="0,0,4,0" />
              <Button Name="AcknowledgeButton" Content="Acknowledge" Padding="10,2" FontSize="12"
                      Command="{Binding AcknowledgeSelectedCommand}"
                      ToolTip.Tip="Mark the selected findings acknowledged (a reversible ignore entry)" />
              <Button Name="SuppressButton" Content="Suppress" Padding="10,2" FontSize="12"
                      Command="{Binding SuppressSelectedCommand}"
                      ToolTip.Tip="Suppress the selected findings (a reversible ignore entry)" />
              <Button Name="UntriageButton" Content="Un-triage" Padding="10,2" FontSize="12"
                      Command="{Binding UntriageSelectedCommand}"
                      ToolTip.Tip="Reopen the selected acknowledged/suppressed findings" />
              <Button Content="Clear" Padding="8,2" FontSize="12"
                      Command="{Binding ClearSelectionCommand}"
                      ToolTip.Tip="Deselect all findings" />
            </StackPanel>
          </Border>

          <!-- Header row. Shares the column track string with the body row template below; the
               sortable headers are flat buttons firing SortCommand with their AuditSortColumn, and
               their caret (via AuditTableConverters.SortCaret) marks the active sort + direction. -->
          <Grid Grid.Row="2" Margin="0,12,0,6"
                ColumnDefinitions="32,28,*,1.4*,Auto,Auto"
                IsVisible="{Binding HasFindings}">
            <!-- Select all / none. -->
            <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0"
                      IsChecked="{Binding AllSelected, Mode=OneWay}"
                      Command="{Binding ToggleSelectAllCommand}"
                      ToolTip.Tip="Select all / none" />
            <!-- Severity (sortable). -->
            <Button Grid.Column="1" Classes="colhead" Padding="0"
                    Command="{Binding SortCommand}"
                    CommandParameter="{x:Static vm:AuditSortColumn.Severity}"
                    ToolTip.Tip="Sort by severity">
              <StackPanel Orientation="Horizontal">
                <TextBlock Classes="eyebrow" Text="SEV" />
                <TextBlock Classes="eyebrow">
                  <TextBlock.Text>
                    <MultiBinding Converter="{x:Static views:AuditTableConverters.SortCaret}"
                                  ConverterParameter="{x:Static vm:AuditSortColumn.Severity}">
                      <Binding Path="SortColumn" />
                      <Binding Path="SortDescending" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </Button>
            <!-- Message (not sortable — free-text). -->
            <TextBlock Grid.Column="2" Classes="eyebrow" Text="MESSAGE" VerticalAlignment="Center" />
            <!-- Object (sortable). -->
            <Button Grid.Column="3" Classes="colhead" HorizontalAlignment="Left" Padding="0"
                    Command="{Binding SortCommand}"
                    CommandParameter="{x:Static vm:AuditSortColumn.ObjectName}"
                    ToolTip.Tip="Sort by object name">
              <StackPanel Orientation="Horizontal">
                <TextBlock Classes="eyebrow" Text="OBJECT" />
                <TextBlock Classes="eyebrow">
                  <TextBlock.Text>
                    <MultiBinding Converter="{x:Static views:AuditTableConverters.SortCaret}"
                                  ConverterParameter="{x:Static vm:AuditSortColumn.ObjectName}">
                      <Binding Path="SortColumn" />
                      <Binding Path="SortDescending" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </Button>
            <!-- Rule class (sortable). -->
            <Button Grid.Column="4" Classes="colhead" HorizontalAlignment="Left" Padding="0"
                    Margin="12,0,0,0" MinWidth="120"
                    Command="{Binding SortCommand}"
                    CommandParameter="{x:Static vm:AuditSortColumn.RuleClass}"
                    ToolTip.Tip="Sort by rule class">
              <StackPanel Orientation="Horizontal">
                <TextBlock Classes="eyebrow" Text="RULE" />
                <TextBlock Classes="eyebrow">
                  <TextBlock.Text>
                    <MultiBinding Converter="{x:Static views:AuditTableConverters.SortCaret}"
                                  ConverterParameter="{x:Static vm:AuditSortColumn.RuleClass}">
                      <Binding Path="SortColumn" />
                      <Binding Path="SortDescending" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </Button>
            <!-- Status (Open / Acknowledged / Suppressed — WP5e). -->
            <TextBlock Grid.Column="5" Classes="eyebrow" Text="STATUS"
                       Margin="12,0,0,0" MinWidth="72" VerticalAlignment="Center" />
          </Grid>

          <!-- Body rows. The ListBox gives the selection affordance + scrolling; each row template
               reuses the SAME column track string as the header so the columns line up (the no-
               DataGrid alignment technique). A row checkbox drives IsSelected; clicking the row
               selects it in the list (the future detail-pane anchor). -->
          <!-- MaxHeight caps the list so the page (not an unbounded card) absorbs long finding lists:
               the ListBox scrolls internally past ~480px while the action bar stays reachable via the
               page ScrollViewer. -->
          <ListBox Grid.Row="3" Name="FindingsList"
                   Background="Transparent"
                   MaxHeight="480"
                   ItemsSource="{Binding Findings}"
                   SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                   IsVisible="{Binding HasFindings}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:AuditFindingRowModel">
                <!-- Triaged rows are muted (still listed + selectable for reversal — ADR-028). The
                     0.6 dim is applied to the CONTENT cells ONLY (severity / message / object / rule),
                     never to the row root: dimming the status pill too would composite its ink+fill
                     toward the card bg and drop the WCAG-proven 6.04:1/8.02:1 below 4.5:1. The
                     checkbox + the status pill therefore stay full-opacity (a child cannot exceed its
                     parent's composited opacity in Avalonia, so the dim must live below the row). -->
                <Grid ColumnDefinitions="32,28,*,1.4*,Auto,Auto" Height="36">

                  <!-- Per-row triage context menu (in-Audit): right-click a row for the same verbs the
                       detail pane exposes. The row IS the DataContext here, so CommandParameter is the
                       row itself ({Binding}); the commands live on the VM, reached via $parent[UserControl]
                       (the same hop the categories-pane buttons use). Un-triage is enabled only on a
                       triaged row. Read-only toward AD — routes through the ADR-028 ignore-entry seam. -->
                  <Grid.ContextFlyout>
                    <MenuFlyout>
                      <MenuItem Header="Acknowledge"
                                IsEnabled="{Binding !IsTriaged}"
                                Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).AcknowledgeRowCommand}"
                                CommandParameter="{Binding}" />
                      <MenuItem Header="Suppress"
                                IsEnabled="{Binding !IsTriaged}"
                                Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SuppressRowCommand}"
                                CommandParameter="{Binding}" />
                      <MenuItem Header="Un-triage"
                                IsEnabled="{Binding IsTriaged}"
                                Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).UntriageRowCommand}"
                                CommandParameter="{Binding}" />
                    </MenuFlyout>
                  </Grid.ContextFlyout>

                  <!-- Select (full opacity — the reversal affordance). -->
                  <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0"
                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            ToolTip.Tip="Select this finding" />

                  <!-- Severity glyph: colored square + redundant letter (E/W/i) — the colourblind-
                       safe channel beside the colour, one SeverityConverters palette. -->
                  <Border Grid.Column="1" Width="20" Height="20" CornerRadius="3"
                          VerticalAlignment="Center" HorizontalAlignment="Left"
                          Opacity="{Binding IsTriaged, Converter={x:Static views:AuditTableConverters.TriagedToOpacity}}"
                          Background="{Binding Severity, Converter={x:Static views:SeverityConverters.ToBrush}}">
                    <TextBlock Text="{Binding Severity, Converter={x:Static views:SeverityConverters.ToGlyph}}"
                               Foreground="{Binding Severity, Converter={x:Static views:SeverityConverters.ToTextBrush}}"
                               FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>

                  <!-- Message. -->
                  <TextBlock Grid.Column="2" Text="{Binding Message}"
                             VerticalAlignment="Center" Margin="4,0,8,0"
                             TextTrimming="CharacterEllipsis"
                             Opacity="{Binding IsTriaged, Converter={x:Static views:AuditTableConverters.TriagedToOpacity}}"
                             ToolTip.Tip="{Binding Message}" />

                  <!-- Object (resolved name; tooltip shows the DN). -->
                  <TextBlock Grid.Column="3" Text="{Binding ObjectName}"
                             VerticalAlignment="Center" Margin="0,0,8,0"
                             TextTrimming="CharacterEllipsis"
                             Opacity="{Binding IsTriaged, Converter={x:Static views:AuditTableConverters.TriagedToOpacity}}"
                             ToolTip.Tip="{Binding PrimaryDn}" />

                  <!-- Rule class. -->
                  <TextBlock Grid.Column="4" Text="{Binding RuleClass}"
                             VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="120"
                             Opacity="{Binding IsTriaged, Converter={x:Static views:AuditTableConverters.TriagedToOpacity}}"
                             Classes="secondary" />

                  <!-- Status pill (WP5e / ADR-028). Two variants share the cell, picked by IsTriaged:
                       Open = a ghost pill (transparent fill, card border, theme secondary ink ≥ 4.5:1);
                       Acknowledged/Suppressed = a filled Info/Warning pill with the WCAG-proven dark
                       OnLightText ink (6.04:1 / 8.02:1). The label TEXT carries the meaning (WCAG 1.4.1);
                       the fill hue is the redundant emphasis cue. -->
                  <Panel Grid.Column="5" Margin="12,0,0,0" MinWidth="72" VerticalAlignment="Center">
                    <!-- Open. -->
                    <Border Padding="8,2" CornerRadius="10" IsVisible="{Binding !IsTriaged}"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                      <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource SecondaryForegroundBrush}" />
                    </Border>
                    <!-- Acknowledged / Suppressed (filled, theme-independent fill + WCAG ink). -->
                    <Border Padding="8,2" CornerRadius="10" IsVisible="{Binding IsTriaged}"
                            Background="{Binding Status, Converter={x:Static views:AuditTableConverters.StatusToFill}}">
                      <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 Foreground="{Binding Status, Converter={x:Static views:AuditTableConverters.StatusToInk}}" />
                    </Border>
                  </Panel>

                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- All-clear: no finding at all (the master list is empty). MinHeight gives the row a
               sensible height when the ListBox above is collapsed (IsVisible=false). -->
          <TextBlock Grid.Row="3" Text="No findings to list."
                     IsVisible="{Binding IsAllClear}"
                     Classes="secondary" VerticalAlignment="Top" MinHeight="32" Margin="0,12,0,0" />

          <!-- WP1 no-matches: findings exist but the active filters hide them all (distinct from the
               all-clear above — HasNoMatches is true only when _allRows is non-empty). -->
          <TextBlock Grid.Row="3" Text="No findings match the current filters."
                     IsVisible="{Binding HasNoMatches}"
                     Classes="secondary" VerticalAlignment="Top" MinHeight="32" Margin="0,12,0,0" />

        </Grid>
      </Border>

      <!-- Detail pane (WP5f / #160): the read-only detail of the ListBox-SELECTED finding. Header
           (rule class + severity glyph + object name/DN), "What's wrong" (message + plain restatement),
           "Why it matters" + numbered "How to fix" (static per-rule-class copy), and a COPY-ONLY
           PowerShell remediation snippet with a PROMINENT preview-only banner. The snippet is INERT
           TEXT — the Copy button writes it to the clipboard; the app NEVER executes it (no Process.Start,
           no shell, no AD call). Theme-aware via DynamicResource; the code block uses FontFamilyMono on
           the page surface (the documented WCAG reference bg) with the theme default foreground
           (~15:1 dark / ~13:1 light — well above 4.5:1). -->
      <!-- MaxHeight caps the detail card so its inner ScrollViewer (below) absorbs long snippets rather
           than ballooning the Auto split row; the page ScrollViewer handles anything past that. -->
      <Border Grid.Column="1" Width="380" MaxHeight="560" Padding="16"
              VerticalAlignment="Top"
              Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}">

        <!-- Empty state: nothing selected. -->
        <Panel>
          <StackPanel IsVisible="{Binding !HasDetail}" VerticalAlignment="Top" Spacing="6">
            <TextBlock Text="Finding detail" Classes="eyebrow" />
            <TextBlock Text="Select a finding from the table to see what is wrong, why it matters, how to fix it, and a copy-only PowerShell remediation snippet."
                       Classes="secondary" TextWrapping="Wrap" />
          </StackPanel>

          <!-- Populated detail. -->
          <ScrollViewer IsVisible="{Binding HasDetail}"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" DataContext="{Binding Detail}"
                        x:CompileBindings="True" x:DataType="vm:AuditFindingDetail">

              <!-- Header: rule-class label + severity glyph + object name + DN. -->
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Width="20" Height="20" CornerRadius="3" VerticalAlignment="Center"
                          Background="{Binding Severity, Converter={x:Static views:SeverityConverters.ToBrush}}">
                    <TextBlock Text="{Binding Severity, Converter={x:Static views:SeverityConverters.ToGlyph}}"
                               Foreground="{Binding Severity, Converter={x:Static views:SeverityConverters.ToTextBrush}}"
                               FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding RuleClassLabel}" Classes="eyebrow" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding ObjectName}" Classes="heading" TextWrapping="Wrap" />
                <SelectableTextBlock Text="{Binding PrimaryDn}" Classes="dn" TextWrapping="Wrap" />
              </StackPanel>

              <!-- What's wrong: the engine message + a plain restatement. -->
              <StackPanel Spacing="4">
                <TextBlock Text="WHAT'S WRONG" Classes="eyebrow" />
                <TextBlock Text="{Binding Message}" Classes="body" TextWrapping="Wrap" />
                <TextBlock Text="{Binding PlainRestatement}" Classes="secondary" TextWrapping="Wrap" />
              </StackPanel>

              <!-- Why it matters: the per-rule-class rationale. -->
              <StackPanel Spacing="4">
                <TextBlock Text="WHY IT MATTERS" Classes="eyebrow" />
                <TextBlock Text="{Binding WhyItMatters}" Classes="body" TextWrapping="Wrap" />
              </StackPanel>

              <!-- How to fix: the per-rule-class numbered steps. -->
              <StackPanel Spacing="4">
                <TextBlock Text="HOW TO FIX" Classes="eyebrow" />
                <ItemsControl ItemsSource="{Binding HowToFix}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <TextBlock Text="{Binding}" Classes="body" TextWrapping="Wrap" Margin="0,1" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Remediation snippet: copy-only PowerShell text. -->
              <StackPanel Spacing="6">
                <TextBlock Text="REMEDIATION (COPY ONLY)" Classes="eyebrow" />

                <!-- PROMINENT preview-only banner: an Info-tinted block restating the read-only
                     invariant. The dark OnLightText ink on the Info-soft fill clears 4.5:1 (the same
                     WCAG-proven pairing the Info badges use). -->
                <Border Background="{x:Static views:BrandTokens.Info}"
                        CornerRadius="6" Padding="10,8">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x2139;" FontWeight="Bold" VerticalAlignment="Top"
                               Foreground="{x:Static views:BrandTokens.OnLightText}" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"
                               Foreground="{x:Static views:BrandTokens.OnLightText}"
                               Text="Preview only — GroupWeaver never changes Active Directory. Review and run this in your own shell." />
                  </StackPanel>
                </Border>

                <!-- The snippet, mono on the page surface (the WCAG reference bg). Selectable so the
                     operator can also hand-pick lines; the Copy button copies the whole snippet. -->
                <Border Background="{DynamicResource PageBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="10,8">
                  <SelectableTextBlock Text="{Binding Snippet}"
                                       FontFamily="{StaticResource FontFamilyMono}"
                                       FontSize="12" TextWrapping="Wrap" />
                </Border>

                <!-- Copy button (clipboard-only; never executes the snippet) + the transient "Copied"
                     affordance. The Click is handled in code-behind: it writes Detail.Snippet to the
                     system clipboard via TopLevel.Clipboard and nothing else. -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Name="CopySnippetButton" Content="Copy"
                          Click="OnCopySnippetClick"
                          ToolTip.Tip="Copy this snippet to the clipboard (it is never run by GroupWeaver)" />
                  <TextBlock Text="Copied to clipboard"
                             Classes="secondary" VerticalAlignment="Center"
                             IsVisible="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SnippetCopied}" />
                </StackPanel>
              </StackPanel>

              <!-- Triage actions (per-row, in-Audit): the detail pane's verbs for the SELECTED finding.
                   These bind to the AuditViewModel (NOT this StackPanel's Detail DataContext) — the
                   commands take the AuditFindingRowModel, which is the VM's SelectedFinding — via the
                   SAME $parent[UserControl] hop the "Copied" caption above uses. Acknowledge/Suppress
                   show only on an Open finding; Un-triage only on a triaged one. Acknowledge/Suppress
                   append an equal-strength tagged global-ignore entry (ADR-028) so the finding drops
                   from the LIVE report (read-only toward AD — the only write is the local ruleset),
                   reversible via Un-triage. After any action the report re-evaluates and SelectedFinding
                   clears, returning this pane to its empty state. -->
              <StackPanel Spacing="6">
                <TextBlock Text="TRIAGE" Classes="eyebrow" />
                <TextBlock
                    Text="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding.StatusLabel, StringFormat='Status: {0}'}"
                    Classes="secondary" />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Name="AcknowledgeRowButton" Content="Acknowledge"
                          IsVisible="{Binding !$parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding.IsTriaged}"
                          Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).AcknowledgeRowCommand}"
                          CommandParameter="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding}"
                          ToolTip.Tip="Mark this finding acknowledged (a reversible ignore entry)" />
                  <Button Name="SuppressRowButton" Content="Suppress"
                          IsVisible="{Binding !$parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding.IsTriaged}"
                          Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SuppressRowCommand}"
                          CommandParameter="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding}"
                          ToolTip.Tip="Suppress this finding (a reversible ignore entry)" />
                  <Button Name="UntriageRowButton" Content="Un-triage"
                          IsVisible="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding.IsTriaged}"
                          Command="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).UntriageRowCommand}"
                          CommandParameter="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).SelectedFinding}"
                          ToolTip.Tip="Reopen this acknowledged/suppressed finding" />
                </StackPanel>
              </StackPanel>

            </StackPanel>
          </ScrollViewer>
        </Panel>
      </Border>

      </Grid>

      <!-- 5b. Run-history compare card (ADR-032 / #190): "Save audit run" persists the LIVE findings
           evidence under %APPDATA%\GroupWeaver\runs\ (read-only toward AD — the only write is the run
           JSON); "Compare to previous run" diffs the live findings against the most recent prior saved
           run for this root and renders the four drift buckets (Fixed / New / Still-open / Now-
           unchecked) with counts. An HONESTY banner fires when either run had unchecked areas (the
           comparison is partial — parallel to the Unchecked caveat above), and a RULESET-MISMATCH
           banner fires when the two runs ran under different rulesets (drift labelled, not blended).
           Mirrors the card/banner styling; theme-aware. The actions arm once the shell installs the
           run-store seam (UseRunStore); CanCompare gates the whole card so a headless audit hides it. -->
      <Border Grid.Row="5" Margin="0,16,0,0" Padding="16"
              IsVisible="{Binding CanCompare}"
              Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}">
        <StackPanel Spacing="12">

          <TextBlock Text="Run history · drift" Classes="eyebrow" />

          <!-- Save + Compare actions + the transient "saved" confirmation. -->
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Name="SaveRunButton" Content="Save audit run"
                    Command="{Binding SaveRunCommand}"
                    ToolTip.Tip="Save this run's findings under %APPDATA%\GroupWeaver\runs\ (read-only — writes only that run file)" />
            <Button Name="CompareRunButton" Content="Compare to previous run"
                    Command="{Binding CompareToPreviousRunCommand}"
                    ToolTip.Tip="Diff the live findings against the most recent prior saved run for this scope" />
            <TextBlock Text="Saved." Classes="secondary" VerticalAlignment="Center"
                       IsVisible="{Binding RunSaved}" />
          </StackPanel>

          <!-- Comparison result (gated on HasComparison). -->
          <StackPanel Spacing="12" DataContext="{Binding Comparison}"
                      x:CompileBindings="True" x:DataType="vm:AuditRunComparison"
                      IsVisible="{Binding $parent[UserControl].((vm:AuditViewModel)DataContext).HasComparison}">

            <!-- No-prior-run hint OR the "vs. run …" context label. -->
            <TextBlock Text="{Binding PreviousRunLabel}" Classes="secondary" TextWrapping="Wrap" />

            <!-- The four drift buckets, only when there IS a prior run to diff against.
                 SURFACE: these tiles fill with PageBackgroundBrush (the OPAQUE page surface), NOT
                 CardBackgroundBrush — unlike the band count tiles in Row 1, these sit INSIDE the
                 compare CARD (itself a translucent CardBackgroundBrush). A CardBackgroundBrush tile
                 there double-composites the translucent card tint over the card, darkening the light
                 fill to ~#DADCDE where SecondaryForegroundBrush ink drops to 4.43:1 (WCAG 1.4.1 fail).
                 The opaque page surface is the single-composite surface the band tiles effectively
                 resolve to: SecondaryForegroundBrush clears 5.25:1 light / 8.01:1 dark with headroom.
                 The colored left-border/dot accent stays the redundant non-text channel; the big
                 count numbers stay theme-default (≈15:1 light / ≈16:1 dark). -->
            <UniformGrid Columns="4" IsVisible="{Binding HasPreviousRun}">
              <!-- Fixed (success green — remediation in a checked area). -->
              <Border Margin="0,0,12,0" Padding="14,12"
                      Background="{DynamicResource PageBackgroundBrush}"
                      BorderBrush="{x:Static views:BrandTokens.NamingOk}"
                      BorderThickness="3,0,0,0" CornerRadius="{StaticResource CardCornerRadius}">
                <StackPanel Spacing="3">
                  <TextBlock Name="FixedCount" Text="{Binding FixedCount}" FontSize="26" FontWeight="Bold" />
                  <TextBlock Text="Fixed" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource SecondaryForegroundBrush}" />
                </StackPanel>
              </Border>
              <!-- New (Error red — newly surfaced findings). -->
              <Border Margin="0,0,12,0" Padding="14,12"
                      Background="{DynamicResource PageBackgroundBrush}"
                      BorderBrush="{x:Static views:BrandTokens.Error}"
                      BorderThickness="3,0,0,0" CornerRadius="{StaticResource CardCornerRadius}">
                <StackPanel Spacing="3">
                  <TextBlock Name="NewCount" Text="{Binding NewCount}" FontSize="26" FontWeight="Bold" />
                  <TextBlock Text="New" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource SecondaryForegroundBrush}" />
                </StackPanel>
              </Border>
              <!-- Still-open (Warning amber — persists across both runs). -->
              <Border Margin="0,0,12,0" Padding="14,12"
                      Background="{DynamicResource PageBackgroundBrush}"
                      BorderBrush="{x:Static views:BrandTokens.Warning}"
                      BorderThickness="3,0,0,0" CornerRadius="{StaticResource CardCornerRadius}">
                <StackPanel Spacing="3">
                  <TextBlock Name="StillOpenCount" Text="{Binding StillOpenCount}" FontSize="26" FontWeight="Bold" />
                  <TextBlock Text="Still open" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource SecondaryForegroundBrush}" />
                </StackPanel>
              </Border>
              <!-- Now-unchecked (neutral — vanished only because unexpanded; never counted as Fixed). -->
              <Border Padding="14,12"
                      Background="{DynamicResource PageBackgroundBrush}"
                      BorderBrush="{DynamicResource CardBorderBrush}"
                      BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}">
                <StackPanel Spacing="3">
                  <TextBlock Name="NowUncheckedCount" Text="{Binding NowUncheckedCount}" FontSize="26" FontWeight="Bold" />
                  <TextBlock Text="Now unchecked" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource SecondaryForegroundBrush}" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <!-- Honesty banner (gated on UncheckedPresent): the SAME tinted info block + glyph as the
                 score's Unchecked caveat — the comparison is partial because an area was not expanded. -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="8,6"
                    IsVisible="{Binding UncheckedPresent}">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="&#x2139;" Classes="secondary"
                           VerticalAlignment="Top" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="One of these runs had unexpanded areas — this comparison is partial; a finding that vanished under an unexpanded parent is counted as Now unchecked, not Fixed."
                           Classes="secondary" TextWrapping="Wrap" />
              </Grid>
            </Border>

            <!-- Ruleset-mismatch banner (gated on RulesetMismatch): drift under a CHANGED ruleset is a
                 different claim — labelled, not blended. Warning-tinted to distinguish it from the
                 neutral honesty banner above. -->
            <Border Background="{x:Static views:BrandTokens.Warning}"
                    CornerRadius="6" Padding="10,8"
                    IsVisible="{Binding RulesetMismatch}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="&#x26A0;" FontWeight="Bold" VerticalAlignment="Top"
                           Foreground="{x:Static views:BrandTokens.OnLightText}" />
                <TextBlock Text="{Binding RulesetMismatchText}"
                           TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"
                           Foreground="{x:Static views:BrandTokens.OnLightText}" />
              </StackPanel>
            </Border>

          </StackPanel>
        </StackPanel>
      </Border>

      <!-- 6. Actions: Back to the workspace (left) + the export pair and "Show in graph" grouped right
           (WP2). Export CSV/HTML write the LIVE post-suppression report (matching the health score +
           sidebar) to a user-picked file — read-only toward AD; the buttons arm once the shell installs
           the export save-picker seam (UseExportFileDialogs). The right group is pushed to the trailing
           edge via a spacer so Back reads as the primary "leave" affordance on the left. -->
      <Grid Grid.Row="6" Margin="0,16,0,0" ColumnDefinitions="Auto,*,Auto">
        <Button Grid.Column="0" Name="BackButton" Content="← Back"
                ToolTip.Tip="Return to the explored structure"
                Command="{Binding BackCommand}" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Name="ExportCsvButton" Content="Export CSV"
                  ToolTip.Tip="Export the current findings to a CSV file (read-only — writes only the file you pick)"
                  Command="{Binding ExportReportCsvCommand}" />
          <Button Name="ExportHtmlButton" Content="Export HTML"
                  ToolTip.Tip="Export the current findings to a self-contained HTML report (read-only — writes only the file you pick)"
                  Command="{Binding ExportReportHtmlCommand}" />
          <Button Name="ShowInGraphButton" Content="Show in graph"
                  ToolTip.Tip="Return to the graph view of the explored structure"
                  Command="{Binding ShowInGraphCommand}" />
        </StackPanel>
      </Grid>

    </Grid>
    </ScrollViewer>
  </Border>

</UserControl>

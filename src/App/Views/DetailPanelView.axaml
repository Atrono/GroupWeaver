<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GroupWeaver.App.ViewModels"
             xmlns:views="using:GroupWeaver.App.Views"
             x:Class="GroupWeaver.App.Views.DetailPanelView"
             x:DataType="vm:DetailPanelModel">

  <!-- Detail panel (AP 2.5 S3, ADR-007): binds ONLY the immutable DetailPanelModel
       projection (D2) - never an AdObject or the snapshot. Lives inside the
       DetailPanelRegion seam BESIDE the graph; nothing here may ever overlay
       GraphHost (ADR-001 airspace guardrail 5). Values wrap and are selectable;
       the panel is the full-value surface (D4) - no truncation, ever. -->
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="12" Spacing="10">

      <!-- Header: kind badge from THE one converter palette (parity with the root
           picker and the graph node colors) + the object name, prominent. -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Border MinWidth="34" VerticalAlignment="Center"
                CornerRadius="3" Padding="5,2"
                Background="{Binding Kind, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
          <TextBlock Text="{Binding Kind, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                     Foreground="White" FontSize="11" FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
        </Border>
        <TextBlock Classes="heading" Text="{Binding Name}"
                   VerticalAlignment="Center" TextWrapping="Wrap"
                   IsVisible="{Binding Name, Converter={x:Static ObjectConverters.IsNotNull}}" />
      </StackPanel>

      <!-- sAMAccountName: a dimmed caption label (parity with the attribute-row
           DataTemplate below, which captions every whitelisted attribute) above the
           verbatim value, so the bare directory string is no longer unlabeled. The
           whole block keeps the original null-check visibility on the SAM line. -->
      <StackPanel IsVisible="{Binding SamAccountName, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock Classes="caption" Text="sAMAccountName" />
        <TextBlock Classes="dn" Text="{Binding SamAccountName}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- The DN, verbatim (never canonicalized) and text-selectable: the one
           copy-source for the full identity of the object. The ghost Copy button
           writes the verbatim DN string to the clipboard (code-behind) and flips a
           transient "Copied" affordance — a pure clipboard write, never an AD write;
           the DN is a typed member, so no non-whitelisted binding is introduced. -->
      <!-- The DN gets the FULL panel width so it wraps across lines (ADR-007 D4: the
           panel is the full-value surface, never truncated); the Copy affordance sits
           on its own row BELOW it so it can never constrain or clip the wrapping DN.
           (A horizontal StackPanel beside the value would measure with infinite width
           and make TextWrapping inert — pushing a long DN and the button off the rail.) -->
      <StackPanel Spacing="4">
        <SelectableTextBlock Classes="dn-strong" Text="{Binding Dn}"
                             TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Name="CopyDnButton" Classes="ghost" Content="Copy"
                  Click="OnCopyDnClick"
                  ToolTip.Tip="Copy this distinguished name to the clipboard" />
          <TextBlock Text="Copied" Classes="secondary"
                     VerticalAlignment="Center" IsVisible="{Binding CopiedDn}" />
        </StackPanel>
      </StackPanel>

      <!-- WP4 (#148) audit-state chips: one chip per finding-bearing rule class
           (max severity + count), or a single green "No findings" chip when clean.
           ENGINE-SOURCED from the RuleReport (RuleId/Severity only) - NO attribute
           data crosses here, so the whitelist baseline below stays intact. Empty
           (collapses) when the panel was built without a report (Plan/Gap) or for a
           frontier DN - graceful, no chips. -->
      <ItemsControl ItemsSource="{Binding AuditChips}"
                    IsVisible="{Binding AuditChips.Count}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:AuditChip">
            <Border CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                    Background="{Binding Converter={x:Static views:SeverityConverters.ChipToBrush}}">
              <TextBlock Text="{Binding Converter={x:Static views:SeverityConverters.ChipToLabel}}"
                         Foreground="{Binding Converter={x:Static views:SeverityConverters.ChipToTextBrush}}"
                         FontSize="11" FontWeight="SemiBold" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Load-state honesty (ADR-007 D3), derived from snapshot state alone. -->
      <TextBlock Classes="secondary"
                 Text="This object is not loaded yet. Double-click it in the graph or press Refresh node to resolve it."
                 IsVisible="{Binding Converter={x:Static views:DetailPanelStateConverters.IsNotLoaded}}"
                 TextWrapping="Wrap" />

      <TextBlock Classes="secondary"
                 Text="Unresolvable: the directory cannot resolve this DN (for example a foreign security principal), so no attributes are available."
                 IsVisible="{Binding Converter={x:Static views:DetailPanelStateConverters.IsUnresolvable}}"
                 TextWrapping="Wrap" />

      <TextBlock Classes="secondary"
                 Text="No whitelisted attributes."
                 IsVisible="{Binding Converter={x:Static views:DetailPanelStateConverters.IsLoadedWithoutAttributes}}"
                 TextWrapping="Wrap" />

      <!-- Attribute rows: the projection's Rows VERBATIM (the D2 mirror - the UI
           never re-filters; a provider whitelist bug must become visible). -->
      <ItemsControl ItemsSource="{Binding Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DetailRow">
            <StackPanel Margin="0,0,0,8">
              <TextBlock Classes="caption" Text="{Binding Label}" />
              <SelectableTextBlock Text="{Binding Value}" TextWrapping="Wrap" />
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- WP4 (#148) privacy-baseline note: a quiet, theme-aware caption on the #91
           card chrome stating exactly how many whitelisted attributes are shown and that
           everything else is withheld by the privacy baseline. N = Rows.Count (the verbatim
           D2 mirror of the provider-filtered Attributes - the count actually shown for THIS
           object). Shown only when attributes are present (Rows.Count > 0), so the
           not-loaded / unresolvable / no-attributes states never carry it. -->
      <Border IsVisible="{Binding Rows.Count}"
              Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
              Padding="10,8" Margin="0,4,0,0">
        <TextBlock Classes="secondary" TextWrapping="Wrap"
                   Text="{Binding PrivacyNote}" />
      </Border>

      <!-- Terminus hairline (#92): a faint top-border rule closing the content stack
           so the under-fill below a short panel reads as deliberate empty space, not
           a clipped/broken region. Render-only chrome on the #91 card-border token;
           touches no binding or the attribute-row realization above. -->
      <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorderBrush}"
              Margin="0,12,0,0" Height="1" />

    </StackPanel>
  </ScrollViewer>

</UserControl>

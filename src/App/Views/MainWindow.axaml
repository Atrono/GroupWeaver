<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupWeaver.App.ViewModels"
        xmlns:views="using:GroupWeaver.App.Views"
        x:Class="GroupWeaver.App.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="GroupWeaver"
        Width="1280" Height="720"
        MinWidth="960" MinHeight="600">

  <!-- Step-switched shell (ADR-003 D5): one DataTemplate per step content type,
       selected by ShellViewModel.CurrentStep. -->
  <Window.DataTemplates>

    <DataTemplate DataType="vm:ConnectionViewModel">
      <views:ConnectionView />
    </DataTemplate>

    <DataTemplate DataType="vm:RootPickerViewModel">
      <views:RootPickerView />
    </DataTemplate>

    <DataTemplate DataType="vm:WorkspaceViewModel">
      <views:WorkspaceView />
    </DataTemplate>

  </Window.DataTemplates>

  <ContentControl Content="{Binding CurrentStep}" />

</Window>

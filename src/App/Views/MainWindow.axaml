<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupWeaver.App.ViewModels"
        xmlns:views="using:GroupWeaver.App.Views"
        x:Class="GroupWeaver.App.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="GroupWeaver"
        Width="1280" Height="720"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource PageBackgroundBrush}">

  <!-- ADR-022 D1: full-screen is a pure view concern (no VM state). F11 toggles
       WindowState between the remembered prior state and FullScreen; Esc exits
       full-screen AND focus mode (the shell's ExitFocusModeCommand). Handled in the
       code-behind OnKeyDown ([I] interactive, like OpenSettings' ShowDialog) — headless
       screenshot fixtures size the window directly and never exercise these. -->

  <!-- Step-switched shell (ADR-003 D5): one DataTemplate per step content type,
       selected by ShellViewModel.CurrentStep. -->
  <Window.DataTemplates>

    <DataTemplate DataType="vm:ConnectionViewModel">
      <views:ConnectionView />
    </DataTemplate>

    <DataTemplate DataType="vm:RootPickerViewModel">
      <views:RootPickerView />
    </DataTemplate>

    <DataTemplate DataType="vm:WorkspaceViewModel">
      <views:WorkspaceView />
    </DataTemplate>

    <DataTemplate DataType="vm:PlanViewModel">
      <views:PlanView />
    </DataTemplate>

    <DataTemplate DataType="vm:GapViewModel">
      <views:GapView />
    </DataTemplate>

    <DataTemplate DataType="vm:AuditViewModel">
      <views:AuditView />
    </DataTemplate>

  </Window.DataTemplates>

  <DockPanel>

    <!-- WebView2-Runtime warning banner (AP 2.1 S7, ADR-003 D3): persistent across ALL
         steps when the startup probe found no runtime — informational only, never a
         dialog, never blocks. DockPanel.Dock=Top keeps it in layout flow ABOVE the step
         content, so it can never overlap the workspace's GraphHost region (ADR-001
         airspace guardrail 5: nothing floats over the native HWND). -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding WebView2Missing}"
            Background="#2EFFB900" BorderBrush="#66FFB900" BorderThickness="0,0,0,1"
            Padding="12,8">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                   Text="The Microsoft Edge WebView2 Runtime was not found. GroupWeaver needs it to display the graph (everything else works). Download:" />
        <Button Grid.Column="1" Classes="hyperlink"
                Margin="8,0,0,0" VerticalAlignment="Center"
                Command="{Binding OpenWebView2DownloadPageCommand}">
          <TextBlock Text="developer.microsoft.com/microsoft-edge/webview2"
                     TextDecorations="Underline" />
        </Button>
      </Grid>
    </Border>

    <!-- Top command strip (AP 3.3 / ADR-011 §1): a thin shell-level bar holding the
         "Settings" affordance, reachable on every step. DockPanel.Dock=Top places it
         BELOW the WebView2 banner and ABOVE the step content, so it sits in layout flow
         and can never overlap the workspace's GraphHost native HWND (ADR-001 airspace
         guardrail 5). The button opens the modal SettingsWindow (its own top-level Window
         per ADR-003 D5 - never layered over the graph). -->
    <!-- ADR-022 D2: focus (presentation) mode hides the top strip — IsVisible binds
         !IsFocusMode. The WebView2-missing banner above stays visible regardless (a
         missing-runtime warning must never be suppressed). -->
    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource CardBorderBrush}"
            Padding="10,5"
            IsVisible="{Binding !IsFocusMode}">
      <!-- ADR-026 D6 (WP2): the strip reads as the redesign's title strip — LEFT-aligned status
           badges (the always-on Read-only lock pill + the demo-gated DEMO badge, with a minimal
           "GW" brand mark) coexist with the RIGHT-aligned theme/Focus/Settings buttons via a
           three-column grid (Auto | * | Auto). The middle * spacer keeps Settings rightmost. -->
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

        <!-- LEFT: brand mark + status badges. -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

          <!-- Minimal "GW" brand mark (the redesign's gradient-tile wordmark, flattened to the
               accent fill so it reads in both themes). Decorative — IsHitTestVisible=False. -->
          <Border Width="20" Height="20" CornerRadius="5" IsHitTestVisible="False"
                  Background="{DynamicResource AccentFillBrush}"
                  VerticalAlignment="Center">
            <TextBlock Text="GW" FontSize="9" FontWeight="Bold" Foreground="#FFFFFF"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          <!-- Read-only lock pill — ALWAYS visible (the product is read-only by design). Green-soft
               pill, green ink, lock glyph + "Read-only" (ADR-026 D6). Theme-aware via tokens. -->
          <Border CornerRadius="6" Padding="9,3" VerticalAlignment="Center"
                  Background="{DynamicResource ReadOnlyPillBackgroundBrush}"
                  ToolTip.Tip="GroupWeaver never writes to Active Directory.">
            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
              <TextBlock Text="🔒" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource ReadOnlyPillTextBrush}" />
              <TextBlock Text="Read-only" FontSize="11" FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource ReadOnlyPillTextBrush}" />
            </StackPanel>
          </Border>

          <!-- DEMO badge — visible ONLY in demo mode (ADR-026 D6). Accent ink on an accent-soft
               pill, letter-spaced mono, mirroring the redesign's title-strip badge. -->
          <Border CornerRadius="6" Padding="6,2" VerticalAlignment="Center"
                  IsVisible="{Binding IsDemoMode}"
                  Background="{DynamicResource AccentSoftBrush}">
            <TextBlock Text="DEMO" FontSize="10" FontWeight="Bold" LetterSpacing="0.6"
                       FontFamily="{StaticResource FontFamilyMono}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DemoBadgeTextBrush}" />
          </Border>

        </StackPanel>

        <!-- RIGHT: theme / Focus / Settings (unchanged order; Settings stays rightmost).
             ADR-022 addendum: the Focus toggle sits to the LEFT of Settings; it binds DIRECTLY to
             ShellViewModel.ToggleFocusModeCommand and shows only on the workspace step
             (IsWorkspaceStep). ADR-026 D4: the theme toggle shows on every step. -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" VerticalAlignment="Center">
          <Button Name="ThemeToggleButton" Padding="10,4"
                  Command="{Binding ToggleThemeCommand}"
                  ToolTip.Tip="{Binding ThemeTooltip}">
            <TextBlock Text="{Binding ThemeGlyph}" />
          </Button>
          <Button Name="FocusModeButton" Padding="10,4"
                  IsVisible="{Binding IsWorkspaceStep}"
                  Command="{Binding ToggleFocusModeCommand}"
                  ToolTip.Tip="Focus mode — hide panels for presentation (F · Esc to exit)">
            <TextBlock Text="⛶ Focus" />
          </Button>
          <!-- Keyboard/gesture cheat sheet ("?"). Quiet, sits left of Settings (Settings stays
               rightmost). Opens the modal KeyboardHelpWindow — its own top-level Window, never
               over the GraphHost (ADR-001 airspace guardrail 5). -->
          <Button Padding="10,4"
                  Command="{Binding OpenKeyboardHelpCommand}"
                  ToolTip.Tip="Keyboard shortcuts">
            <TextBlock Text="?" />
          </Button>
          <Button HorizontalAlignment="Right" Padding="10,4"
                  Command="{Binding OpenSettingsCommand}">
            <TextBlock Text="⚙ Settings" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- #122 (ADR-025): the step content sits over an always-attached, hidden, zero-size
         "parking lot" Panel SIBLING in the same fill region. The GraphSurfaceCoordinator
         (built in MainWindow.OnOpened) parks a step's live graph surface HERE, still ROOTED,
         BEFORE the DataTemplate swap detaches the leaving view — so the WebView2 page +
         cytoscape viewport survive a Back round-trip (the ParkSpike GO finding: survival is
         continuous rootedness, not BeginReparenting). A Panel (multi-child) because Workspace
         and the current Plan can be parked at once. IsVisible=false + zero-size keeps the
         native HWND from painting over anything (ADR-001 airspace guardrail 5). -->
    <Panel>
      <ContentControl Content="{Binding CurrentStep}" />
      <Panel x:Name="ParkingLot" IsVisible="False" Width="0" Height="0"
             HorizontalAlignment="Left" VerticalAlignment="Top" />
    </Panel>

  </DockPanel>

</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupWeaver.App.ViewModels"
        xmlns:views="using:GroupWeaver.App.Views"
        x:Class="GroupWeaver.App.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="GroupWeaver"
        Width="1280" Height="720"
        MinWidth="960" MinHeight="600">

  <!-- ADR-022 D1: full-screen is a pure view concern (no VM state). F11 toggles
       WindowState between the remembered prior state and FullScreen; Esc exits
       full-screen AND focus mode (the shell's ExitFocusModeCommand). Handled in the
       code-behind OnKeyDown ([I] interactive, like OpenSettings' ShowDialog) — headless
       screenshot fixtures size the window directly and never exercise these. -->

  <!-- Step-switched shell (ADR-003 D5): one DataTemplate per step content type,
       selected by ShellViewModel.CurrentStep. -->
  <Window.DataTemplates>

    <DataTemplate DataType="vm:ConnectionViewModel">
      <views:ConnectionView />
    </DataTemplate>

    <DataTemplate DataType="vm:RootPickerViewModel">
      <views:RootPickerView />
    </DataTemplate>

    <DataTemplate DataType="vm:WorkspaceViewModel">
      <views:WorkspaceView />
    </DataTemplate>

    <DataTemplate DataType="vm:PlanViewModel">
      <views:PlanView />
    </DataTemplate>

    <DataTemplate DataType="vm:GapViewModel">
      <views:GapView />
    </DataTemplate>

  </Window.DataTemplates>

  <DockPanel>

    <!-- WebView2-Runtime warning banner (AP 2.1 S7, ADR-003 D3): persistent across ALL
         steps when the startup probe found no runtime — informational only, never a
         dialog, never blocks. DockPanel.Dock=Top keeps it in layout flow ABOVE the step
         content, so it can never overlap the workspace's GraphHost region (ADR-001
         airspace guardrail 5: nothing floats over the native HWND). -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding WebView2Missing}"
            Background="#2EFFB900" BorderBrush="#66FFB900" BorderThickness="0,0,0,1"
            Padding="12,8">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                   Text="The Microsoft Edge WebView2 Runtime was not found. GroupWeaver needs it to display the graph (everything else works). Download:" />
        <Button Grid.Column="1" Classes="hyperlink"
                Margin="8,0,0,0" VerticalAlignment="Center"
                Command="{Binding OpenWebView2DownloadPageCommand}">
          <TextBlock Text="developer.microsoft.com/microsoft-edge/webview2"
                     TextDecorations="Underline" />
        </Button>
      </Grid>
    </Border>

    <!-- Top command strip (AP 3.3 / ADR-011 §1): a thin shell-level bar holding the
         "Settings" affordance, reachable on every step. DockPanel.Dock=Top places it
         BELOW the WebView2 banner and ABOVE the step content, so it sits in layout flow
         and can never overlap the workspace's GraphHost native HWND (ADR-001 airspace
         guardrail 5). The button opens the modal SettingsWindow (its own top-level Window
         per ADR-003 D5 - never layered over the graph). -->
    <!-- ADR-022 D2: focus (presentation) mode hides the top strip — IsVisible binds
         !IsFocusMode. The WebView2-missing banner above stays visible regardless (a
         missing-runtime warning must never be suppressed). -->
    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="#33808080"
            Padding="8,4"
            IsVisible="{Binding !IsFocusMode}">
      <!-- ADR-022 addendum: the Focus toggle (the entry point D2 specified but the first cut
           omitted) sits to the LEFT of Settings, so Settings stays rightmost. It binds DIRECTLY
           to ShellViewModel.ToggleFocusModeCommand (focus mode is shell chrome — it hides this
           very strip) and shows only on the workspace step (IsWorkspaceStep), keeping the
           Connect/RootPicker strips byte-identical. -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Name="FocusModeButton" Padding="10,4"
                IsVisible="{Binding IsWorkspaceStep}"
                Command="{Binding ToggleFocusModeCommand}"
                ToolTip.Tip="Focus mode — hide panels for presentation (F · Esc to exit)">
          <TextBlock Text="⛶ Focus" />
        </Button>
        <Button HorizontalAlignment="Right" Padding="10,4"
                Command="{Binding OpenSettingsCommand}">
          <TextBlock Text="⚙ Settings" />
        </Button>
      </StackPanel>
    </Border>

    <ContentControl Content="{Binding CurrentStep}" />

  </DockPanel>

</Window>

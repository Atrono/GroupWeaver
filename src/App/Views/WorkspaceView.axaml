<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GroupWeaver.App.ViewModels"
             xmlns:views="using:GroupWeaver.App.Views"
             x:Class="GroupWeaver.App.Views.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel">

  <!-- Workspace step (AP 2.1): the airspace-shaped layout (ADR-003 D5, ADR-001
       guardrail 5). GraphHost is the reserved center region the AP 2.2 WebView's
       native child HWND mounts into; the detail panel lives BESIDE it in its own
       grid column and the status bar BELOW it. NOTHING may ever be styled to
       float, popup, or otherwise layer over GraphHost - the native HWND wins
       every airspace fight. Anything genuinely modal must be its own Window. -->
  <Grid RowDefinitions="*,Auto">

    <Grid Grid.Row="0" ColumnDefinitions="*,300">

      <ContentControl Grid.Column="0" Name="GraphHost">
        <!-- Two placeholder variants switched on the runtime probe (AP 2.1 S7,
             ADR-003 D3); the code-behind swaps this content for the renderer's
             surface when a graph renderer exists (AP 2.2 S6, ADR-004 D5). -->
        <Panel>

          <StackPanel IsVisible="{Binding !WebView2Missing}" Spacing="8"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Graph view is unavailable in this environment."
                       FontSize="20" HorizontalAlignment="Center" />
            <TextBlock Classes="dn" Text="{Binding RootDn}"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </StackPanel>

          <StackPanel IsVisible="{Binding WebView2Missing}" Spacing="8" MaxWidth="520"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="The Microsoft Edge WebView2 Runtime was not found."
                       FontSize="20" TextWrapping="Wrap" TextAlignment="Center" />
            <TextBlock Text="GroupWeaver needs it to display the graph (everything else works). Download:"
                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" />
            <Button Classes="hyperlink" HorizontalAlignment="Center"
                    Command="{Binding OpenWebView2DownloadPageCommand}">
              <TextBlock Text="developer.microsoft.com/microsoft-edge/webview2"
                         TextDecorations="Underline" />
            </Button>
          </StackPanel>

        </Panel>
      </ContentControl>

      <!-- Right column (AP 3.4 S4, ADR-010 §5): a vertical split (2*,Auto,3*) of the
           existing right column - the violations sidebar tops it (row 0), a 1px
           separator (row 1), and the existing Refresh / LoadError / DetailPanelRegion
           stack below (row 2). Beside GraphHost, never over it (ADR-001 airspace
           guardrail 5); GraphHost (col 0) is untouched. -->
      <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="#33808080">
        <Grid RowDefinitions="2*,Auto,3*">

          <!-- Violations sidebar (AP 3.4): binds the workspace VM's report projection
               (S5 fills Evaluate); shows the all-clear state until then. -->
          <views:ViolationsSidebarView Grid.Row="0" />

          <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#33808080" />

          <Grid Grid.Row="2" RowDefinitions="Auto,Auto,*">

            <!-- Detail-column header (AP 2.3 S4 / issue #30): whole-scope Reload
                 (selection-independent, re-runs LoadScopeAsync for the root) beside
                 per-node Refresh (forced re-fetch of the selected node, ADR-005 D4).
                 Native chrome BESIDE the graph, ABOVE the AP 2.5 DetailPanelRegion
                 seam - never over GraphHost (ADR-001 airspace guardrail 5). -->
            <!-- Two right-aligned rows so the AP 4.2.2 "Design plan" button gets its own
                 line ABOVE the existing trio — four buttons do not fit one row inside the
                 fixed 300px detail column, and the existing Reload→Refresh→Export order +
                 their single-row geometry stay pinned. Both rows live BESIDE GraphHost,
                 never over it (ADR-001 guardrail 5). -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="12,12,12,0"
                        HorizontalAlignment="Right">

              <!-- Design plan (AP 4.2.2 / ADR-014): switch into Plan Mode to author a
                   proposed structure. The command's CanExecute is armed once the shell
                   installs the switch callback (when this workspace becomes the step). -->
              <Button Name="DesignPlanButton" Content="Design plan" HorizontalAlignment="Right"
                      ToolTip.Tip="Design a proposed structure and validate it live"
                      Command="{Binding DesignPlanCommand}" />

              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Name="ReloadScopeButton" Content="Reload scope"
                        ToolTip.Tip="Reload the whole scope from the directory"
                        Command="{Binding ReloadScopeCommand}" />
                <Button Name="RefreshButton" Content="Refresh"
                        ToolTip.Tip="Re-fetch members of the selected node"
                        Command="{Binding RefreshCommand}" />
                <!-- Export image (AP 4.1 S8 / ADR-013): rasterise the live graph to PNG
                     via the renderer's cy.png round-trip and save it to a user-picked file.
                     Native chrome beside the graph, never over GraphHost (ADR-001 airspace
                     guardrail 5); the command's CanExecute disables it while IsLoading or
                     with no renderer / export seam. -->
                <Button Name="ExportGraphImageButton" Content="Export image"
                        ToolTip.Tip="Save the current graph as a PNG image"
                        Command="{Binding ExportGraphImageCommand}" />
              </StackPanel>

            </StackPanel>

            <!-- Inline load/renderer error (ADR-003 D7: DirectoryUnavailable only, no
                 demo hint - a connection already succeeded). Top of the detail column,
                 never over GraphHost (ADR-001 airspace guardrail 5). -->
            <TextBlock Grid.Row="1" Margin="12,12,12,0"
                       Text="{Binding LoadError}"
                       IsVisible="{Binding LoadError, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Foreground="#C42B1C" TextWrapping="Wrap" />

            <!-- Detail panel (AP 2.5, ADR-007 D2): the view binds ONLY the immutable
                 DetailPanelModel projection - never an AdObject or the snapshot. The
                 wrapper Panel carries the visibility switch because its DataContext
                 is still the workspace VM; the inner view's is the projection. -->
            <ContentControl Grid.Row="2" Name="DetailPanelRegion">
              <Panel>
                <TextBlock Text="Click a node to inspect it."
                           IsVisible="{Binding DetailPanel, Converter={x:Static ObjectConverters.IsNull}}"
                           Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Panel IsVisible="{Binding DetailPanel, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <views:DetailPanelView DataContext="{Binding DetailPanel}" />
                </Panel>
              </Panel>
            </ContentControl>

          </Grid>

        </Grid>
      </Border>

    </Grid>

    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#33808080">
      <DockPanel Margin="12,6">
        <TextBlock DockPanel.Dock="Right" Margin="24,0,0,0"
                   Text="{Binding RootDn, StringFormat='root: {0}'}"
                   FontSize="12" Opacity="0.7" />
        <ProgressBar DockPanel.Dock="Right" Margin="24,0,0,0" Width="120"
                     IsIndeterminate="True" IsVisible="{Binding IsLoading}" />
        <!-- Drawn-graph summary ("n objects, m edges", AP 2.2 S6) between the
             connection summary and the root DN; null until the load completed. -->
        <TextBlock DockPanel.Dock="Right" Margin="24,0,0,0"
                   Text="{Binding GraphSummary}"
                   IsVisible="{Binding GraphSummary, Converter={x:Static ObjectConverters.IsNotNull}}"
                   FontSize="12" Opacity="0.7" />
        <TextBlock Text="{Binding ConnectionSummary}"
                   FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
      </DockPanel>
    </Border>

  </Grid>

</UserControl>

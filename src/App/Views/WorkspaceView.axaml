<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GroupWeaver.App.ViewModels"
             xmlns:views="using:GroupWeaver.App.Views"
             x:Class="GroupWeaver.App.Views.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel">

  <!-- ADR-022 D3: Ctrl+B toggles the rail collapse. The UserControl-level binding
       keeps the gesture live wherever focus sits inside the workspace. -->
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+B" Command="{Binding ToggleRailCommand}" />
  </UserControl.KeyBindings>

  <!-- Workspace step (AP 2.1): the airspace-shaped layout (ADR-003 D5, ADR-001
       guardrail 5). GraphHost is the reserved center region the AP 2.2 WebView's
       native child HWND mounts into; the detail panel lives BESIDE it in its own
       grid column and the status bar BELOW it. NOTHING may ever be styled to
       float, popup, or otherwise layer over GraphHost - the native HWND wins
       every airspace fight. Anything genuinely modal must be its own Window. -->
  <Grid RowDefinitions="*,Auto">

    <!-- ADR-022 D3: *, Auto, {rail} — col 0 GraphHost (untouched), col 1 the thin native
         SEAM (GridSplitter + always-present ◂/▸ collapse toggle), col 2 the adaptive rail.
         The rail column width binds RailColumnWidth two-way (RailWidth px / 0 when collapsed);
         the splitter resizes it, the toggle collapses it. Everything stays to the RIGHT of
         GraphHost, never over it (ADR-001 airspace guardrail 5). -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="{Binding RailColumnWidth, Mode=TwoWay}" />
      </Grid.ColumnDefinitions>

      <ContentControl Grid.Column="0" Name="GraphHost">
        <!-- Two placeholder variants switched on the runtime probe (AP 2.1 S7,
             ADR-003 D3); the code-behind swaps this content for the renderer's
             surface when a graph renderer exists (AP 2.2 S6, ADR-004 D5). -->
        <Panel>

          <StackPanel IsVisible="{Binding !WebView2Missing}" Spacing="8"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Graph view is unavailable in this environment."
                       FontSize="20" HorizontalAlignment="Center" />
            <TextBlock Classes="dn" Text="{Binding RootDn}"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </StackPanel>

          <StackPanel IsVisible="{Binding WebView2Missing}" Spacing="8" MaxWidth="520"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="The Microsoft Edge WebView2 Runtime was not found."
                       FontSize="20" TextWrapping="Wrap" TextAlignment="Center" />
            <TextBlock Text="GroupWeaver needs it to display the graph (everything else works). Download:"
                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" />
            <Button Classes="hyperlink" HorizontalAlignment="Center"
                    Command="{Binding OpenWebView2DownloadPageCommand}">
              <TextBlock Text="developer.microsoft.com/microsoft-edge/webview2"
                         TextDecorations="Underline" />
            </Button>
          </StackPanel>

        </Panel>
      </ContentControl>

      <!-- The native SEAM (ADR-022 D3, col 1): the airspace-safe home for the rail
           affordances when collapsed (ADR-001 intact — beside GraphHost, never over it).
           Holds the GridSplitter (hidden when collapsed) overlaid with the always-present
           ◂/▸ collapse toggle. The toggle's chevron reflects IsRailCollapsed (▸ = expand
           when collapsed, ◂ = collapse when open). -->
      <Panel Grid.Column="1" Width="28">
        <GridSplitter Width="6" HorizontalAlignment="Center"
                      ResizeDirection="Columns" Background="Transparent"
                      IsVisible="{Binding !IsRailCollapsed}" />
        <!-- The pill is a centered ~28px band so the full-height splitter stays grabbable
             above and below it; it reads as a control (ghost border + hover) and its
             chevron/tooltip flip with IsRailCollapsed (▸ expand / ◂ collapse). -->
        <Button Name="RailCollapseToggle" Classes="ghost"
                Width="28" Height="32" Padding="0" MinWidth="0"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Command="{Binding ToggleRailCommand}"
                ToolTip.Tip="{Binding IsRailCollapsed, Converter={x:Static views:RailChevronConverter.ToTooltip}}">
          <!-- Vector chevron (ADR-022 D3): a filled PathIcon gets clean grayscale edge AA
               on the near-black seam — no subpixel colour fringe a triangle font glyph shows
               at small size. ◂ collapse when open / ▸ expand when collapsed (ToGeometry). -->
          <PathIcon Width="9" Height="9"
                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Data="{Binding IsRailCollapsed, Converter={x:Static views:RailChevronConverter.ToGeometry}}" />
        </Button>
      </Panel>

      <!-- Right column (AP 3.4 S4, ADR-010 §5; ADR-022 D3 col 2): a vertical split of the
           rail - the violations sidebar tops it (row 0), a draggable hairline splitter (row 1),
           and the Reload / Refresh / Export action row + LoadError + DetailPanelRegion stack
           below (row 2). WP-B (#178): rows 0/2 bind the VM's persisted star fractions
           (FindingsRowHeight / DetailRowHeight, default 1:1) instead of the old fixed 2*,Auto,3*,
           and the 1px separator became a Rows GridSplitter so the user can resize findings vs.
           detail. The whole rail hides when collapsed (the column width is already 0; IsVisible
           keeps it out of the layout pass). Beside GraphHost, never over it (ADR-001 airspace
           guardrail 5); GraphHost (col 0) is untouched. -->
      <Border Grid.Column="2" BorderThickness="1,0,0,0" BorderBrush="#33808080"
              IsVisible="{Binding !IsRailCollapsed}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="{Binding FindingsRowHeight}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{Binding DetailRowHeight}" />
          </Grid.RowDefinitions>

          <!-- Violations sidebar (AP 3.4): binds the workspace VM's report projection
               (S5 fills Evaluate); shows the all-clear state until then. -->
          <views:ViolationsSidebarView Grid.Row="0" />

          <!-- WP-B (#178): the findings/detail resize handle - a Rows GridSplitter that keeps the
               old hairline look (a thin #33808080 line) with a taller transparent grab band around
               it so it stays easy to hit. Rows 0/2 stay ONE-WAY bound to the VM star getters (no
               jitter): the splitter mutates the live RowDefinitions during the drag, and the
               code-behind DragCompleted handler syncs+clamps+persists the fraction on release.
               Inside col 2 (the rail), never over GraphHost (ADR-001 airspace guardrail 5). -->
          <GridSplitter Grid.Row="1" Name="FindingsDetailSplitter"
                        ResizeDirection="Rows" Height="7"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Background="Transparent"
                        ToolTip.Tip="Drag to resize findings vs. detail">
            <GridSplitter.Template>
              <ControlTemplate>
                <Border Background="Transparent">
                  <Border Height="1" VerticalAlignment="Center"
                          HorizontalAlignment="Stretch" Background="#33808080" />
                </Border>
              </ControlTemplate>
            </GridSplitter.Template>
          </GridSplitter>

          <Grid Grid.Row="2" RowDefinitions="Auto,Auto,*">

            <!-- Detail-column action row (AP 2.3 S4 / issue #30; ADR-022 D5): the four
                 actions (Design plan / Reload scope / Refresh / Export image) reflow into
                 ONE right-aligned WrapPanel that wraps only at the rail minimum, retiring
                 the forced two-row stack. All Name / Command / tooltip / CanExecute bindings
                 are kept verbatim (existing tests reference these button names). Native
                 chrome BESIDE the graph, ABOVE the AP 2.5 DetailPanelRegion seam — never over
                 GraphHost (ADR-001 airspace guardrail 5). -->
            <WrapPanel Grid.Row="0" Margin="12,12,12,0"
                       HorizontalAlignment="Right" Orientation="Horizontal">

              <!-- Design plan (AP 4.2.2 / ADR-014): switch into Plan Mode to author a
                   proposed structure. The command's CanExecute is armed once the shell
                   installs the switch callback (when this workspace becomes the step). -->
              <Button Name="DesignPlanButton" Content="Design plan" Margin="4"
                      ToolTip.Tip="Design a proposed structure and validate it live"
                      Command="{Binding DesignPlanCommand}" />
              <Button Name="ReloadScopeButton" Content="Reload scope" Margin="4"
                      ToolTip.Tip="Reload the whole scope from the directory"
                      Command="{Binding ReloadScopeCommand}" />
              <!-- WP4 (#148): the detail panel's primary CTA ("Expand members" in the
                   redesign) - re-fetch the selected node's members. WP-B (#178): the brand accent
                   is now CONDITIONAL on a node being selected (IsNodeSelected) - it re-fetches the
                   SELECTED node's members, so it should only read as the loud primary control when
                   that action is meaningful; with nothing selected it drops to a plain/default
                   button (and is disabled by RefreshCommand's CanExecute anyway). Name / Command /
                   tooltip / content unchanged (tests reference the name). -->
              <Button Name="RefreshButton" Content="Refresh" Margin="4"
                      Classes.accent="{Binding IsNodeSelected}"
                      ToolTip.Tip="Re-fetch members of the selected node"
                      Command="{Binding RefreshCommand}" />
              <!-- Export image (AP 4.1 S8 / ADR-013): rasterise the live graph to PNG
                   via the renderer's cy.png round-trip and save it to a user-picked file.
                   Native chrome beside the graph, never over GraphHost (ADR-001 airspace
                   guardrail 5); the command's CanExecute disables it while IsLoading or
                   with no renderer / export seam. -->
              <Button Name="ExportGraphImageButton" Content="Export image" Margin="4"
                      ToolTip.Tip="Save the current graph as a PNG image"
                      Command="{Binding ExportGraphImageCommand}" />
              <!-- Audit (WP5 / #152): switch into the audit step to see the dashboard health
                   roll-up over the loaded scope. Placed LAST in the right-aligned WrapPanel so it
                   never disturbs the pinned Reload-scope→Refresh adjacency. CanExecute arms once
                   the shell installs the switch callback AND a load has completed (Snapshot
                   non-null). -->
              <Button Name="AuditButton" Classes="accent-outline" Margin="12,4,4,4"
                      ToolTip.Tip="Audit this scope — health score and findings summary"
                      Command="{Binding AuditCommand}">
                <!-- WP3 (#152): the headline health-verdict destination — promoted to the
                     accent-OUTLINE tier (App.axaml) with a leading shield-check glyph so it
                     reads as "go here for the verdict", distinct from the grey ghosts and the
                     filled-accent Refresh. The glyph is an inline vector Path (font-independent
                     ⇒ renders in headless Skia, no missing-glyph box), Fill = the same accent
                     ink as the label. The "Audit" text stays a reachable TextBlock. The extra
                     left margin (12) detaches it from the graph-action cluster without a
                     reflow-breaking separator element; the button stays LAST. -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path VerticalAlignment="Center"
                        Fill="{DynamicResource AccentTextBrush}"
                        Data="F1 M7,0 L13,2 V7 C13,11 10.4,13.2 7,14 C3.6,13.2 1,11 1,7 V2 Z
                              M5.1,6.4 L4,7.5 L6.2,9.7 L10.4,5.5 L9.3,4.4 L6.2,7.5 Z" />
                  <TextBlock Text="Audit" VerticalAlignment="Center" />
                </StackPanel>
              </Button>

            </WrapPanel>

            <!-- Inline load/renderer error (ADR-003 D7: DirectoryUnavailable only, no
                 demo hint - a connection already succeeded). Top of the detail column,
                 never over GraphHost (ADR-001 airspace guardrail 5). -->
            <TextBlock Grid.Row="1" Margin="12,12,12,0"
                       Text="{Binding LoadError}"
                       IsVisible="{Binding LoadError, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Foreground="#C42B1C" TextWrapping="Wrap" />

            <!-- Detail panel (AP 2.5, ADR-007 D2): the view binds ONLY the immutable
                 DetailPanelModel projection - never an AdObject or the snapshot. The
                 wrapper Panel carries the visibility switch because its DataContext
                 is still the workspace VM; the inner view's is the projection. -->
            <ContentControl Grid.Row="2" Name="DetailPanelRegion">
              <Panel>

                <!-- ADR-022 D5 (reframed, #186): with nothing selected the empty rail reads as
                     information, not a void — a compact scope-summary card (active ruleset name +
                     object/edge totals) on the #91 card tokens, with a one-line "click a node" hint
                     at the bottom. The old per-kind / severity tallies were removed as redundant
                     (graph legend + findings chip strip). Replaces the old centered placeholder. -->
                <Border Name="ScopeSummaryCard"
                        IsVisible="{Binding DetailPanel, Converter={x:Static ObjectConverters.IsNull}}"
                        Margin="12"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="12" VerticalAlignment="Top">
                  <StackPanel Spacing="10">

                    <TextBlock Text="Scope summary" Classes="heading" />

                    <!-- The active ruleset: the one audit-orientation fact shown nowhere else in
                         the chrome (mirrors the status-bar 'root:' provenance line). Updates live
                         on a settings apply (ADR-022 D5 reframe, #186). -->
                    <TextBlock Text="{Binding RulesetName, StringFormat='Ruleset: {0}'}"
                               Classes="secondary" TextWrapping="Wrap" />

                    <!-- Object / edge totals (reuses GraphSummary; null until first load). -->
                    <TextBlock Text="{Binding GraphSummary}"
                               Classes="secondary" TextWrapping="Wrap"
                               IsVisible="{Binding GraphSummary, Converter={x:Static ObjectConverters.IsNotNull}}" />

                    <!-- The one-line inspect hint stays at the bottom of the card. -->
                    <TextBlock Text="Click a node to inspect it."
                               Classes="secondary" TextWrapping="Wrap" Margin="0,2,0,0" />

                  </StackPanel>
                </Border>

                <Panel IsVisible="{Binding DetailPanel, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <views:DetailPanelView DataContext="{Binding DetailPanel}" />
                </Panel>
              </Panel>
            </ContentControl>

          </Grid>

        </Grid>
      </Border>

    </Grid>

    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#33808080">
      <DockPanel Margin="12,6">
        <TextBlock DockPanel.Dock="Right" Margin="24,0,0,0"
                   Text="{Binding RootDn, StringFormat='root: {0}'}"
                   FontSize="12" Opacity="0.7" />
        <ProgressBar DockPanel.Dock="Right" Margin="24,0,0,0" Width="120"
                     IsIndeterminate="True" IsVisible="{Binding IsLoading}" />
        <!-- Drawn-graph summary ("n objects, m edges", AP 2.2 S6) between the
             connection summary and the root DN; null until the load completed. -->
        <TextBlock DockPanel.Dock="Right" Margin="24,0,0,0"
                   Text="{Binding GraphSummary}"
                   IsVisible="{Binding GraphSummary, Converter={x:Static ObjectConverters.IsNotNull}}"
                   FontSize="12" Opacity="0.7" />
        <TextBlock Text="{Binding ConnectionSummary}"
                   FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
      </DockPanel>
    </Border>

  </Grid>

</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:settings="using:GroupWeaver.App.Settings"
        xmlns:views="using:GroupWeaver.App.Views"
        xmlns:rules="using:GroupWeaver.Core.Rules"
        xmlns:model="using:GroupWeaver.Core.Model"
        x:Class="GroupWeaver.App.Views.SettingsWindow"
        x:DataType="settings:SettingsViewModel"
        Title="GroupWeaver Settings"
        Width="900" Height="640"
        MinWidth="720" MinHeight="520"
        Background="{DynamicResource PageBackgroundBrush}">

  <Window.Styles>
    <!-- WP6b: the demo-preview signed delta (+3 / -1 / 0). Neutral (equal/fewer than default)
         reads in the secondary chrome ink; the .caution class (more than default) re-tones to the
         theme-aware caution amber. Color is REDUNDANT — the signed text always carries meaning. -->
    <Style Selector="TextBlock.previewDelta">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
    </Style>
    <Style Selector="TextBlock.previewDelta.caution">
      <Setter Property="Foreground" Value="{DynamicResource PreviewCautionTextBrush}" />
    </Style>
  </Window.Styles>

  <Window.Resources>

    <!-- WP6b: one demo-preview delta chip — "{Label} {+n/-n/0}", the value re-toned via
         Classes.caution (more-than-default). Reused by the per-severity and per-rule-class rows. -->
    <DataTemplate x:Key="PreviewDeltaTemplate" x:DataType="settings:PreviewDelta">
      <StackPanel Orientation="Horizontal" Spacing="3" Margin="0,0,12,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding Label}" Opacity="0.75" VerticalAlignment="Center" />
        <TextBlock Classes="previewDelta" Classes.caution="{Binding IsCaution}"
                   Text="{Binding DisplayValue}" FontWeight="SemiBold" VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>

    <!-- Shared severity-selector item template (AP 3.3 / S6): the E/W/i glyph in the
         pinned SeverityConverters palette (#D13438/#F7A30B/#4FA3E3) + the name label.
         Reused by the Naming-tab cards AND the Rules-tab master grid so every severity
         selector in the editor reads in lock-step with the sidebar glyphs. -->
    <DataTemplate x:Key="SeverityItemTemplate" x:DataType="rules:RuleSeverity">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Border Width="18" Height="18" CornerRadius="3"
                Background="{Binding Converter={x:Static views:SeverityConverters.ToBrush}}">
          <TextBlock Text="{Binding Converter={x:Static views:SeverityConverters.ToGlyph}}"
                     Foreground="{Binding Converter={x:Static views:SeverityConverters.ToTextBrush}}"
                     FontSize="11" FontWeight="SemiBold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>

    <!-- Shared nesting-matrix cell-choice item template (AP 3.3 / S6): a compact colored
         chip — green ✓ allow, neutral ✗ deny, E/W/i in the ADR-010 palette for a per-cell
         severity override — so a cell reads as a colored chip without opening its ComboBox.
         Reused by the 18 matrix cells AND the Unlisted-fallback selector. -->
    <DataTemplate x:Key="CellChoiceItemTemplate" x:DataType="settings:CellChoice">
      <Border MinWidth="58" CornerRadius="3" Padding="6,1"
              Background="{Binding Converter={x:Static views:CellChoiceConverters.ToBrush}}">
        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
          <TextBlock Text="{Binding Converter={x:Static views:CellChoiceConverters.ToGlyph}}"
                     Foreground="{Binding Converter={x:Static views:CellChoiceConverters.ToTextBrush}}"
                     FontSize="11" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding}"
                     Foreground="{Binding Converter={x:Static views:CellChoiceConverters.ToTextBrush}}"
                     FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- One matrix cell (AP 3.3 / S6): a ContentControl in the 3×6 grid binds a
         NestingCellEditor as its Content, this template re-scopes the compiled-binding
         x:DataType to that cell so the ComboBox's SelectedItem="{Binding Choice}" resolves
         against the cell (and the realized control's DataContext IS the cell — the matrix
         soundness pin). The chip ItemTemplate renders the colored verdict. -->
    <DataTemplate x:Key="MatrixCellTemplate" x:DataType="settings:NestingCellEditor">
      <ComboBox HorizontalAlignment="Stretch"
                SelectedItem="{Binding Choice}"
                ItemsSource="{x:Static settings:CellChoiceItems.All}"
                ItemTemplate="{StaticResource CellChoiceItemTemplate}" />
    </DataTemplate>

    <!-- One ignore-list row (AP 3.3 / S7): the global ignore list's MatchEntryEditor.
         dn/name mode toggle over a single Value glob (the UI enforces the dn-XOR-name —
         BuildRuleset sets exactly one, the Load gate re-checks), a free-form Note TextBox,
         an optional "does this glob match?" helper, and a Remove button. The endpoint is
         NEVER shown here (the ignore list is not endpoint-bearing — EndpointEditable=false).
         #45: the Note is EDITED in a TextBox (Text target — never a format/markup surface);
         there is no separate tooltip-on-raw-value. Remove binds to the VM (the ItemsControl's
         DataContext is the SettingsViewModel). -->
    <DataTemplate x:Key="IgnoreRowTemplate" x:DataType="settings:MatchEntryEditor">
      <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorderBrush}" Padding="2,6">
        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
          <ComboBox Grid.Row="0" Grid.Column="0" MinWidth="78" VerticalAlignment="Center"
                    SelectedItem="{Binding Mode}">
            <ComboBox.Items>
              <settings:EntryMode>Dn</settings:EntryMode>
              <settings:EntryMode>Name</settings:EntryMode>
            </ComboBox.Items>
          </ComboBox>
          <TextBox Grid.Row="0" Grid.Column="1" Margin="6,0,0,0" Watermark="glob (e.g. *,CN=Builtin,*)"
                   Text="{Binding Value}" VerticalAlignment="Center" />
          <!-- Remove binds to the VM (the ItemsControl's DataContext): reflection binding —
               the parent path is not statically typed under this row's MatchEntryEditor x:DataType. -->
          <Button Grid.Row="0" Grid.Column="2" Margin="6,0,0,0" Content="Remove"
                  x:CompileBindings="False"
                  Command="{Binding $parent[ItemsControl].DataContext.RemoveIgnoreCommand}"
                  CommandParameter="{Binding}" />
          <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,0,0,0"
                   Watermark="note (optional)" Text="{Binding Note}" />
        </Grid>
      </Border>
    </DataTemplate>

    <!-- One per-rule EXCEPTION row (AP 3.3 / S7): the same MatchEntryEditor, reused by every
         exception list. The Endpoint ComboBox (Any/Parent/Member) is shown ONLY when
         EndpointEditable is true — i.e. ONLY for nesting exceptions (the one legal place);
         naming/circular/empty-group exceptions hide it and Build forces Any. Remove binds to
         the OWNING editor (the ItemsControl's DataContext is the section editor — Nesting /
         a naming rule / Circular / EmptyGroup — each exposing RemoveExceptionCommand). #45:
         the Note is edited in a TextBox (a plain Text target). -->
    <DataTemplate x:Key="ExceptionRowTemplate" x:DataType="settings:MatchEntryEditor">
      <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorderBrush}" Padding="2,6">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
          <ComboBox Grid.Row="0" Grid.Column="0" MinWidth="78" VerticalAlignment="Center"
                    SelectedItem="{Binding Mode}">
            <ComboBox.Items>
              <settings:EntryMode>Dn</settings:EntryMode>
              <settings:EntryMode>Name</settings:EntryMode>
            </ComboBox.Items>
          </ComboBox>
          <TextBox Grid.Row="0" Grid.Column="1" Margin="6,0,0,0" Watermark="glob"
                   Text="{Binding Value}" VerticalAlignment="Center" />
          <!-- Endpoint: nesting exceptions only (Any/Parent/Member). -->
          <ComboBox Grid.Row="0" Grid.Column="2" Margin="6,0,0,0" MinWidth="92" VerticalAlignment="Center"
                    IsVisible="{Binding EndpointEditable}"
                    SelectedItem="{Binding Endpoint}">
            <ComboBox.Items>
              <rules:MatchEndpoint>Any</rules:MatchEndpoint>
              <rules:MatchEndpoint>Parent</rules:MatchEndpoint>
              <rules:MatchEndpoint>Member</rules:MatchEndpoint>
            </ComboBox.Items>
          </ComboBox>
          <!-- Remove binds to the OWNING editor (the ItemsControl's DataContext — Nesting /
               a naming rule / Circular / EmptyGroup, all exposing RemoveExceptionCommand):
               reflection binding, since the owner type varies and is not the row's x:DataType. -->
          <Button Grid.Row="0" Grid.Column="3" Margin="6,0,0,0" Content="Remove"
                  x:CompileBindings="False"
                  Command="{Binding $parent[ItemsControl].DataContext.RemoveExceptionCommand}"
                  CommandParameter="{Binding}" />
          <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="6,0,0,0"
                   Watermark="note (optional)" Text="{Binding Note}" />
        </Grid>
      </Border>
    </DataTemplate>

  </Window.Resources>

  <!-- The modal settings editor (AP 3.3 / ADR-011 §1): a separate top-level Window
       (ADR-003 D5's sanctioned escape hatch — never layered over the workspace
       GraphHost, ADR-001 airspace guardrail 5). The editable mirror tree
       (SettingsViewModel) is the DataContext; RulesetLoader.Load is the single
       save/import/apply gate behind the footer. This slice (S5) ships the TabControl
       shell, the persistent validation band + footer (OUTSIDE the tabs), and the
       Naming tab with live preview; S6/S7 fill the other tabs. -->
  <DockPanel>

    <!-- Footer (OUTSIDE the TabControl): Apply = live re-thread, no disk write;
         Save = live + atomic persist; Cancel closes. S8 wires Apply/Save commands
         and the shell re-thread; this slice ships the affordance. -->
    <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorderBrush}"
            Padding="12,8">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="ghost" Content="Apply" MinWidth="84" Command="{Binding ApplyActionCommand}" />
        <Button Classes="accent" Content="Save" MinWidth="84" IsDefault="True" Command="{Binding SaveActionCommand}" />
        <Button Classes="ghost" Content="Cancel" MinWidth="84" IsCancel="True" Click="OnCancelClick" />
      </StackPanel>
    </Border>

    <!-- Persistent validation band (OUTSIDE the TabControl, above the footer): the
         loader's path-addressed errors from the most recent gate or a rejected
         user-file-on-open. Path and Message bind to SEPARATE Text targets — Message
         is STRICTLY plain text (#45: untrusted files may carry control chars), never
         interpolated into a format template or markup surface. Hidden when clean. -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding ValidationErrors.Count}"
            Background="#22D13438" BorderBrush="#66D13438" BorderThickness="0,1,0,0"
            Padding="12,8" MaxHeight="160">
      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding ValidationErrors}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="rules:RulesetValidationError">
              <!-- DockPanel (not a horizontal StackPanel): a StackPanel gives children
                   INFINITE width so TextWrapping="Wrap" never engages and a long loader
                   message is clipped at the window edge. Docking the Path left bounds the
                   message's width to the remaining row, so Wrap actually wraps at MinWidth.
                   #45: Path + Message stay SEPARATE plain-text targets, never interpolated. -->
              <DockPanel Margin="0,1" LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Path}"
                           FontFamily="{StaticResource FontFamilyMono}"
                           Opacity="0.7" VerticalAlignment="Top" Margin="0,0,6,0" />
                <SelectableTextBlock Text="{Binding Message}"
                                     Foreground="{DynamicResource ValidationErrorTextBrush}"
                                     TextWrapping="Wrap" />
              </DockPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- Invalid-user-file banner (above the tabs): the app is running on the embedded
         default because the saved file was rejected; the broken file is left
         byte-unchanged on disk (ADR-011 open-risk #2). -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding RunningOnDefaultBecauseInvalid}"
            Background="#2EFFB900" BorderBrush="#66FFB900" BorderThickness="0,0,0,1"
            Padding="12,8">
      <TextBlock TextWrapping="Wrap"
                 Text="Your saved ruleset could not be loaded; GroupWeaver is running on the built-in default. Fix the errors below and Save, or Reset to default." />
    </Border>

    <TabControl Padding="0">

      <!-- Rules master grid (AP 3.3 / S6): one row per rule in the EnumerateRules shape —
           the nesting matrix, every naming rule (file order), circular, empty-group — each
           a 2-way Enabled toggle + Severity selector reading/writing THROUGH the owning
           section editor (RuleRowEditor, so the grid and the per-section tabs can never
           disagree). The severity selector reuses the shared SeverityItemTemplate, so each
           row's E/W/i glyph reads in the pinned SeverityConverters palette. -->
      <TabItem Header="Rules">
        <ScrollViewer>
          <StackPanel Margin="12" Spacing="2">
            <!-- Eye-line affordance (v0.4.2 polish): the rule name (left) and its severity
                 control (far right of the * column) sit a long way apart, so a full-row
                 pointer-over wash ties the two together on hover - the theme-aware GhostHoverBrush
                 (dark #14FFFFFF / light #0D000000), the SAME wash Button.ghost uses. The base
                 rule sets a Transparent rest fill so the whole row (not just its glyphs) is
                 hit-test-visible across the * gap; BOTH live at Style priority so the more-specific
                 :pointerover setter actually wins (an inline Background="Transparent" would be a
                 LocalValue that outranks the style and silently swallows the hover - Avalonia
                 value precedence). -->
            <StackPanel.Styles>
              <Style Selector="Border.ruleRow">
                <Setter Property="Background" Value="Transparent" />
              </Style>
              <Style Selector="Border.ruleRow:pointerover">
                <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
              </Style>
            </StackPanel.Styles>

            <TextBlock Opacity="0.6" TextWrapping="Wrap" Margin="2,0,0,8"
                       Text="Every rule, with its on/off toggle and severity. Edit a rule's details on its own tab (Naming, Matrix); changes here and there stay in sync." />

            <!-- Header row -->
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,0,4,4">
              <TextBlock Grid.Column="0" Text="On" FontWeight="SemiBold" Opacity="0.7" />
              <TextBlock Grid.Column="1" Text="Rule" FontWeight="SemiBold" Opacity="0.7"
                         Margin="10,0,0,0" />
              <TextBlock Grid.Column="2" Text="Severity" FontWeight="SemiBold" Opacity="0.7"
                         Margin="10,0,0,0" />
            </Grid>

            <ItemsControl ItemsSource="{Binding Rules}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settings:RuleRowEditor">
                  <Border Classes="ruleRow"
                          BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorderBrush}" Padding="4,6">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                IsChecked="{Binding Enabled}" />
                      <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Margin="10,0,0,0"
                                 VerticalAlignment="Center" TextWrapping="NoWrap" />
                      <ComboBox Grid.Column="2" Margin="10,0,0,0" MinWidth="120"
                                VerticalAlignment="Center"
                                SelectedItem="{Binding Severity}"
                                ItemTemplate="{StaticResource SeverityItemTemplate}">
                        <ComboBox.Items>
                          <rules:RuleSeverity>Error</rules:RuleSeverity>
                          <rules:RuleSeverity>Warning</rules:RuleSeverity>
                          <rules:RuleSeverity>Info</rules:RuleSeverity>
                        </ComboBox.Items>
                      </ComboBox>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Naming">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Naming}" Margin="12">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="settings:NamingRuleEditor">

                <!-- One naming-rule card: Id/Enabled/Severity/Kind/Pattern/Description,
                     a PreviewSample TextBox, and the live-preview chip. #93: the outer card
                     chrome adopts the shared structural-neutral tokens (card border / radius /
                     padding) — inner controls + bindings untouched (soundness pins). -->
                <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="12" Margin="0,0,0,10">
                  <StackPanel Spacing="8">

                    <!-- Header row: enabled toggle, id, severity glyph, kind badge. -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                      <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                IsChecked="{Binding Enabled}" />
                      <TextBox Grid.Column="1" Watermark="rule id" Margin="6,0,0,0"
                               Text="{Binding Id}" VerticalAlignment="Center" />

                      <!-- Severity selector: each item shows the E/W/i glyph square in
                           the SeverityConverters palette (parity with the sidebar). -->
                      <ComboBox Grid.Column="2" Margin="8,0,0,0" MinWidth="120"
                                VerticalAlignment="Center"
                                SelectedItem="{Binding Severity}"
                                ItemTemplate="{StaticResource SeverityItemTemplate}">
                        <ComboBox.Items>
                          <rules:RuleSeverity>Error</rules:RuleSeverity>
                          <rules:RuleSeverity>Warning</rules:RuleSeverity>
                          <rules:RuleSeverity>Info</rules:RuleSeverity>
                        </ComboBox.Items>
                      </ComboBox>

                      <!-- Kind selector: the 6 legal kinds (External pre-filtered — the
                           loader rejects it), each badged via AdObjectKindConverters. -->
                      <ComboBox Grid.Column="3" Margin="8,0,0,0" MinWidth="120"
                                VerticalAlignment="Center"
                                SelectedItem="{Binding Kind}">
                        <ComboBox.Items>
                          <model:AdObjectKind>User</model:AdObjectKind>
                          <model:AdObjectKind>Computer</model:AdObjectKind>
                          <model:AdObjectKind>GlobalGroup</model:AdObjectKind>
                          <model:AdObjectKind>DomainLocalGroup</model:AdObjectKind>
                          <model:AdObjectKind>UniversalGroup</model:AdObjectKind>
                          <model:AdObjectKind>OrganizationalUnit</model:AdObjectKind>
                        </ComboBox.Items>
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="model:AdObjectKind">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <Border MinWidth="30" CornerRadius="3" Padding="4,1"
                                      Background="{Binding Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                                <TextBlock Text="{Binding Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                                           Foreground="White" FontSize="10" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </Grid>

                    <TextBox Watermark="^GG_..._..._$ (regex)" Text="{Binding Pattern}" />
                    <TextBox Watermark="description" Text="{Binding Description}" />

                    <!-- Live preview: a candidate sample TextBox + the verdict chip.
                         The chip's DataContext is the NamingPreviewConverter result over
                         [Pattern, PreviewSample, Severity] (a throwaway, never-interned
                         NonBacktracking regex — ADR-009); it renders the verdict glyph in
                         the verdict brush and a plain-text caption. #45: the PatternInvalid
                         Message binds to SelectableTextBlock.Text, never a markup surface. -->
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBox Grid.Column="0" Watermark="GG_Vertrieb_Lesen"
                               Text="{Binding PreviewSample}" />
                      <!-- The chip carries the NamingPreviewVisual on its Tag (NOT DataContext:
                           a MultiBinding on DataContext would re-root its own [Pattern,
                           PreviewSample, Severity] children against the result and read null;
                           Tag is a plain property, so the children resolve against the card).
                           The converter compiles a throwaway, never-interned NonBacktracking
                           regex (ADR-009); the inner controls read Glyph/Brush/Message off the
                           Tag by ElementName. #45: Message binds to SelectableTextBlock.Text. -->
                      <Border Grid.Column="1" Name="PreviewChip" Margin="8,0,0,0"
                              CornerRadius="4" Padding="8,4" VerticalAlignment="Center"
                              BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}">
                        <Border.Tag>
                          <MultiBinding Converter="{x:Static views:NamingPreviewConverter.Instance}">
                            <Binding Path="Pattern" />
                            <Binding Path="PreviewSample" />
                            <Binding Path="Severity" />
                          </MultiBinding>
                        </Border.Tag>
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    x:CompileBindings="False">
                          <TextBlock Text="{Binding #PreviewChip.Tag.Glyph}"
                                     Foreground="{Binding #PreviewChip.Tag.Brush}"
                                     FontWeight="Bold" VerticalAlignment="Center" />
                          <!-- Verdict caption: "matches" (Ok) / "would be flagged
                               ({severity})" (Violation), in the verdict brush. Plain text
                               (TextBlock.Text); empty for Idle/PatternInvalid (the latter
                               shows its diagnostic in the Message line below). -->
                          <TextBlock Text="{Binding #PreviewChip.Tag.Caption}"
                                     Foreground="{Binding #PreviewChip.Tag.Brush}"
                                     IsVisible="{Binding #PreviewChip.Tag.Caption, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                     FontWeight="SemiBold" VerticalAlignment="Center" />
                          <SelectableTextBlock Text="{Binding #PreviewChip.Tag.Message}"
                                               IsVisible="{Binding #PreviewChip.Tag.Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Opacity="0.8" VerticalAlignment="Center"
                                               TextWrapping="Wrap" MaxWidth="220" />
                        </StackPanel>
                      </Border>
                    </Grid>

                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </TabItem>

      <!-- Nesting matrix editor (AP 3.3 / S6): a fixed 3×6 explicit grid — rows (parent)
           GG/DL/UG × columns (member) User/Computer/GG/DL/UG/External (OU excluded, the
           loader rejects an OU column). Row/column headers are kind badges (AdObjectKind
           converters) so the AGUDLP lane reads by color. Each of the 18 cells binds to its
           NestingCellEditor (indexer binding into the canonical parent-major Cells list) so
           a cell control's DataContext IS the editor — a compact ComboBox over Choice whose
           items render a colored allow/deny/E/W/i chip. Below: the Unlisted fallback, the
           rule-wide deny severity, and the nesting Enabled toggle, then the two simple-rule
           cards (circular + empty-group). -->
      <TabItem Header="Matrix">
        <ScrollViewer>
          <StackPanel Margin="12" Spacing="12">

            <DockPanel>
              <CheckBox DockPanel.Dock="Right" VerticalAlignment="Center"
                        Content="Nesting check enabled" IsChecked="{Binding Nesting.Enabled}" />
              <TextBlock Text="Allowed nesting (parent ← member)" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </DockPanel>

            <!-- The 3×6 matrix: row 0 = column-header badges, rows 1-3 = the parent bands.
                 Column 0 = the row-header badge column; columns 1-6 = the member cells. -->
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnDefinitions="Auto,*,*,*,*,*,*" ColumnSpacing="4" RowSpacing="4">

              <!-- Column headers (member kinds), badged. -->
              <Border Grid.Row="0" Grid.Column="1" CornerRadius="3" Padding="4,1" MinWidth="30"
                      Background="{Binding Source={x:Static model:AdObjectKind.User}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.User}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <Border Grid.Row="0" Grid.Column="2" CornerRadius="3" Padding="4,1" MinWidth="30"
                      Background="{Binding Source={x:Static model:AdObjectKind.Computer}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.Computer}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <Border Grid.Row="0" Grid.Column="3" CornerRadius="3" Padding="4,1" MinWidth="30"
                      Background="{Binding Source={x:Static model:AdObjectKind.GlobalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.GlobalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <Border Grid.Row="0" Grid.Column="4" CornerRadius="3" Padding="4,1" MinWidth="30"
                      Background="{Binding Source={x:Static model:AdObjectKind.DomainLocalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.DomainLocalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <Border Grid.Row="0" Grid.Column="5" CornerRadius="3" Padding="4,1" MinWidth="30"
                      Background="{Binding Source={x:Static model:AdObjectKind.UniversalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.UniversalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <Border Grid.Row="0" Grid.Column="6" CornerRadius="3" Padding="4,1" MinWidth="30"
                      Background="{Binding Source={x:Static model:AdObjectKind.External}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.External}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>

              <!-- Row 1: GlobalGroup parent (cells 0-5). -->
              <Border Grid.Row="1" Grid.Column="0" CornerRadius="3" Padding="4,1" MinWidth="30" VerticalAlignment="Center"
                      Background="{Binding Source={x:Static model:AdObjectKind.GlobalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.GlobalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding Nesting.Cells[0]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding Nesting.Cells[1]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="1" Grid.Column="3" Content="{Binding Nesting.Cells[2]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="1" Grid.Column="4" Content="{Binding Nesting.Cells[3]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="1" Grid.Column="5" Content="{Binding Nesting.Cells[4]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="1" Grid.Column="6" Content="{Binding Nesting.Cells[5]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />

              <!-- Row 2: DomainLocalGroup parent (cells 6-11). -->
              <Border Grid.Row="2" Grid.Column="0" CornerRadius="3" Padding="4,1" MinWidth="30" VerticalAlignment="Center"
                      Background="{Binding Source={x:Static model:AdObjectKind.DomainLocalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.DomainLocalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <ContentControl Grid.Row="2" Grid.Column="1" Content="{Binding Nesting.Cells[6]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="2" Grid.Column="2" Content="{Binding Nesting.Cells[7]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="2" Grid.Column="3" Content="{Binding Nesting.Cells[8]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="2" Grid.Column="4" Content="{Binding Nesting.Cells[9]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="2" Grid.Column="5" Content="{Binding Nesting.Cells[10]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="2" Grid.Column="6" Content="{Binding Nesting.Cells[11]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />

              <!-- Row 3: UniversalGroup parent (cells 12-17). -->
              <Border Grid.Row="3" Grid.Column="0" CornerRadius="3" Padding="4,1" MinWidth="30" VerticalAlignment="Center"
                      Background="{Binding Source={x:Static model:AdObjectKind.UniversalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeBrush}}">
                <TextBlock Text="{Binding Source={x:Static model:AdObjectKind.UniversalGroup}, Converter={x:Static views:AdObjectKindConverters.ToBadgeLabel}}"
                           Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" />
              </Border>
              <ContentControl Grid.Row="3" Grid.Column="1" Content="{Binding Nesting.Cells[12]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="3" Grid.Column="2" Content="{Binding Nesting.Cells[13]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="3" Grid.Column="3" Content="{Binding Nesting.Cells[14]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="3" Grid.Column="4" Content="{Binding Nesting.Cells[15]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="3" Grid.Column="5" Content="{Binding Nesting.Cells[16]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />
              <ContentControl Grid.Row="3" Grid.Column="6" Content="{Binding Nesting.Cells[17]}" ContentTemplate="{StaticResource MatrixCellTemplate}" />

            </Grid>

            <!-- Fallback + rule-wide deny severity. -->
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Unlisted (fallback) →"
                         VerticalAlignment="Center" />
              <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="100"
                        SelectedItem="{Binding Nesting.Unlisted}"
                        ItemTemplate="{StaticResource CellChoiceItemTemplate}"
                        ItemsSource="{x:Static settings:CellChoiceItems.All}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Default severity for deny cells →"
                         VerticalAlignment="Center" />
              <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="120"
                        SelectedItem="{Binding Nesting.Severity}"
                        ItemTemplate="{StaticResource SeverityItemTemplate}">
                <ComboBox.Items>
                  <rules:RuleSeverity>Error</rules:RuleSeverity>
                  <rules:RuleSeverity>Warning</rules:RuleSeverity>
                  <rules:RuleSeverity>Info</rules:RuleSeverity>
                </ComboBox.Items>
              </ComboBox>
            </Grid>

            <TextBlock Opacity="0.6" TextWrapping="Wrap"
                       Text="Deny uses the default severity; pick Error/Warning/Info to override one cell." />

            <!-- The two simple-rule cards (circular + empty-group): Enabled + Severity, the
                 same two rules surfaced as rows in the Rules master grid. Their RuleId is
                 fixed and invisible (reconstructed from RuleIds on build). -->
            <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" CornerRadius="6" Padding="12">
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                <CheckBox Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                          IsChecked="{Binding Circular.Enabled}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Circular nesting (A → B → A)"
                           Margin="8,0,0,0" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="2" MinWidth="120" VerticalAlignment="Center"
                          SelectedItem="{Binding Circular.Severity}"
                          ItemTemplate="{StaticResource SeverityItemTemplate}">
                  <ComboBox.Items>
                    <rules:RuleSeverity>Error</rules:RuleSeverity>
                    <rules:RuleSeverity>Warning</rules:RuleSeverity>
                    <rules:RuleSeverity>Info</rules:RuleSeverity>
                  </ComboBox.Items>
                </ComboBox>

                <CheckBox Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                          IsChecked="{Binding EmptyGroup.Enabled}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Empty groups"
                           Margin="8,0,0,0" VerticalAlignment="Center" />
                <ComboBox Grid.Row="1" Grid.Column="2" MinWidth="120" VerticalAlignment="Center"
                          SelectedItem="{Binding EmptyGroup.Severity}"
                          ItemTemplate="{StaticResource SeverityItemTemplate}">
                  <ComboBox.Items>
                    <rules:RuleSeverity>Error</rules:RuleSeverity>
                    <rules:RuleSeverity>Warning</rules:RuleSeverity>
                    <rules:RuleSeverity>Info</rules:RuleSeverity>
                  </ComboBox.Items>
                </ComboBox>
              </Grid>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Ignore & Exceptions (AP 3.3 / S7): the global ignore list (MatchEntryEditor rows —
           dn/name mode toggle + Value glob + Note + Add/Remove; endpoint hidden) followed by
           the per-rule exception lists. The endpoint Any/Parent/Member control appears ONLY on
           the nesting exception rows (EndpointEditable=true — the one legal place); every other
           exception list hides it. #45: every Note is edited in a plain TextBox Text target,
           never a format/markup surface. Suppression order is global ignore → per-rule
           exceptions (ADR-008 §5); this tab surfaces both in that order. -->
      <TabItem Header="Ignore &amp; Exceptions">
        <ScrollViewer>
          <StackPanel Margin="12" Spacing="8">

            <!-- Global ignore list. -->
            <DockPanel>
              <Button DockPanel.Dock="Right" Content="Add ignore entry"
                      Command="{Binding AddIgnoreCommand}" />
              <TextBlock Text="Global ignore list" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>
            <TextBlock Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,2"
                       Text="Objects or edges matching any entry are exempt from every check (global ignore → per-rule exceptions → check). A dn entry globs the DN; a name entry globs Name or SamAccountName." />
            <ItemsControl ItemsSource="{Binding Ignore}"
                          ItemTemplate="{StaticResource IgnoreRowTemplate}" />

            <!-- Per-rule exceptions: nesting (endpoint editable), each naming rule, circular,
                 empty-group. The endpoint control is bound to EndpointEditable, so only the
                 nesting rows render it. -->
            <TextBlock Text="Per-rule exceptions" FontWeight="SemiBold" Margin="0,8,0,0" />

            <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" CornerRadius="6" Padding="10">
              <StackPanel Spacing="4">
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="Add exception"
                          Command="{Binding Nesting.AddExceptionCommand}" />
                  <TextBlock Text="Nesting matrix (endpoint: Any / Parent / Member)"
                             VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl DataContext="{Binding Nesting}" ItemsSource="{Binding Exceptions}"
                              ItemTemplate="{StaticResource ExceptionRowTemplate}" />
              </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Naming}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settings:NamingRuleEditor">
                  <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" CornerRadius="6" Padding="10" Margin="0,4,0,0">
                    <StackPanel Spacing="4">
                      <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Add exception"
                                Command="{Binding AddExceptionCommand}" />
                        <TextBlock Text="{Binding Id, StringFormat='Naming: {0}'}"
                                   VerticalAlignment="Center" />
                      </DockPanel>
                      <ItemsControl ItemsSource="{Binding Exceptions}"
                                    ItemTemplate="{StaticResource ExceptionRowTemplate}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" CornerRadius="6" Padding="10" Margin="0,4,0,0">
              <StackPanel Spacing="4">
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="Add exception"
                          Command="{Binding Circular.AddExceptionCommand}" />
                  <TextBlock Text="Circular nesting" VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl DataContext="{Binding Circular}" ItemsSource="{Binding Exceptions}"
                              ItemTemplate="{StaticResource ExceptionRowTemplate}" />
              </StackPanel>
            </Border>

            <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" CornerRadius="6" Padding="10" Margin="0,4,0,0">
              <StackPanel Spacing="4">
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="Add exception"
                          Command="{Binding EmptyGroup.AddExceptionCommand}" />
                  <TextBlock Text="Empty groups" VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl DataContext="{Binding EmptyGroup}" ItemsSource="{Binding Exceptions}"
                              ItemTemplate="{StaticResource ExceptionRowTemplate}" />
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- File (AP 3.3 / S7): Import / Export / Reset wired through the IRulesetFileDialogs seam
           (the production StorageProvider adapter is the [I] picker layer). Import replaces the
           WHOLE mirror from a picked file IF it loads cleanly (ADR-008 whole-file precedence, no
           merge); Export runs the save gate and writes the gate-re-parsed ruleset to a picked
           path (blocked + errors if invalid); Reset rebuilds the mirror from the embedded default
           (in-memory only — no disk write). All gate/replace LOGIC is in the VM (S3); these
           buttons only invoke it. Save/Apply (footer) persist/re-thread (S8). -->
      <TabItem Header="File">
        <StackPanel Margin="16" Spacing="10">
          <TextBlock FontWeight="SemiBold" Text="Import / Export / Reset" />
          <TextBlock Opacity="0.6" TextWrapping="Wrap"
                     Text="Import replaces the whole ruleset from a file (no merge). Export writes the current ruleset to a file (only if it is valid). Reset to default discards edits in memory — nothing is saved until you press Save." />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Import…" MinWidth="110" Command="{Binding ImportCommand}" />
            <Button Content="Export…" MinWidth="110" Command="{Binding ExportCommand}" />
            <Button Content="Reset to default" MinWidth="130" Command="{Binding ResetCommand}" />
          </StackPanel>
        </StackPanel>
      </TabItem>

      <!-- Advanced (JSONC) — the raw-text ruleset editor (WP6a). ADDED alongside the
           structured tabs (which keep the loader gate + live naming preview); it does NOT
           replace them. The editor text is UNTRUSTED input that only ever flows through
           RulesetLoader.Load (RawEditorErrors below) — never executed/formatted/interpolated;
           errors render as PLAIN text (#45). The single write path stays the loader gate:
           "Apply JSONC" parses RawEditorText, and on success makes the re-parsed ruleset
           effective AND re-seeds the structured tabs (whole-file replace, ADR-008). Live
           finding-count + diff-from-default is WP6b — NOT built here. Syntax highlighting is
           deferred (v1 = a plain monospace TextBox); a line-number gutter scroll-syncs by
           sharing the ONE outer ScrollViewer over the gutter + editor. -->
      <TabItem Header="Advanced (JSONC)">
        <DockPanel Margin="12">

          <TextBlock DockPanel.Dock="Top" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,8"
                     Text="Edit the ruleset as raw JSONC. Load current pulls in what the other tabs hold; Apply JSONC parses this text and, if valid, replaces the whole ruleset (the structured tabs re-seed to match). Nothing is applied or saved until you press Apply JSONC, Apply, or Save." />

          <!-- Action strip: Load current (re-seed the text from the structured mirror) and
               Apply JSONC (parse → gate → make effective + re-seed structured / surface errors). -->
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Load current" MinWidth="110" Command="{Binding SeedRawEditorCommand}" />
            <Button Classes="accent" Content="Apply JSONC" MinWidth="120" Command="{Binding ApplyRawActionCommand}" />
          </StackPanel>

          <!-- Live inline validation band (above the editor): RulesetLoader.Load over the
               editor text on every keystroke (the loader is cheap — ADR-009). Path + Message
               bind to SEPARATE plain-text targets (#45 — never a format/markup surface). A
               green "valid" line shows when the text loads cleanly. Does NOT auto-apply. -->
          <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                  IsVisible="{Binding RawEditorErrors.Count}"
                  Background="#22D13438" BorderBrush="#66D13438" BorderThickness="1"
                  CornerRadius="4" Padding="10,6" MaxHeight="140">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding RawEditorErrors}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="rules:RulesetValidationError">
                    <!-- DockPanel (not a horizontal StackPanel): a StackPanel gives children
                         INFINITE width so TextWrapping="Wrap" never engages and a long loader
                         message is clipped at the window edge (the band has no horizontal
                         scroll). Docking the Path left bounds the message's width to the
                         remaining row, so Wrap actually wraps at the 720px MinWidth. #45: Path
                         + Message stay SEPARATE plain-text targets, never interpolated. -->
                    <DockPanel Margin="0,1" LastChildFill="True">
                      <TextBlock DockPanel.Dock="Left" Text="{Binding Path}"
                                 FontFamily="{StaticResource FontFamilyMono}"
                                 Opacity="0.7" VerticalAlignment="Top" Margin="0,0,6,0" />
                      <SelectableTextBlock Text="{Binding Message}"
                                           Foreground="{DynamicResource ValidationErrorTextBrush}"
                                           TextWrapping="Wrap" />
                    </DockPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
          <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                  IsVisible="{Binding RawEditorValid}"
                  Background="#1F46C98A" BorderBrush="#6646C98A" BorderThickness="1"
                  CornerRadius="4" Padding="10,6">
            <TextBlock Text="Valid JSONC — Apply JSONC to make it the effective ruleset."
                       Foreground="{DynamicResource ReadOnlyPillTextBrush}" />
          </Border>

          <!-- Live demo preview (WP6b / #164): the currently-VALID edited ruleset evaluated over
               the EMBEDDED DEMO snapshot (never the live directory; pure in-memory, writes nothing)
               via RuleEngine.Evaluate + AuditSummary.Compute, joined against the default ruleset's
               demo counts. Shows the total + per-severity counts and the signed diff-from-default
               (per-severity + per-rule-class). The signed delta TEXT (+3 / -1 / 0) always carries
               the meaning; the caution re-tone (more-than-default) is a redundant color cue. The
               card is hidden unless HasPreview; the "unavailable" line covers a failed demo load. -->
          <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                  IsVisible="{Binding HasPreview}"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                  CornerRadius="4" Padding="10,8">
            <StackPanel Spacing="6">
              <TextBlock Text="Demo preview (this ruleset over the built-in demo directory)"
                         FontWeight="SemiBold" Opacity="0.85" />

              <!-- Live counts: total + per-severity squares (the pinned E/W/i palette). -->
              <StackPanel Orientation="Horizontal" Spacing="14">
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding Preview.Total, StringFormat='{}{0} findings'}"
                           FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Border Width="16" Height="16" CornerRadius="3" Background="{x:Static views:BrandTokens.Error}">
                    <TextBlock Text="E" Foreground="{x:Static views:BrandTokens.OnDarkText}"
                               FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding Preview.Critical}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Border Width="16" Height="16" CornerRadius="3" Background="{x:Static views:BrandTokens.Warning}">
                    <TextBlock Text="W" Foreground="{x:Static views:BrandTokens.OnLightText}"
                               FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding Preview.Warning}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Border Width="16" Height="16" CornerRadius="3" Background="{x:Static views:BrandTokens.Info}">
                    <TextBlock Text="i" Foreground="{x:Static views:BrandTokens.OnLightText}"
                               FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding Preview.Info}" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>

              <!-- Diff-from-default: per-severity signed deltas (always shown, even 0). Each signed
                   value re-tones via Classes.caution (more-than-default = amber) — a redundant cue
                   over the always-present sign. -->
              <WrapPanel Orientation="Horizontal">
                <TextBlock Text="vs default:" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ContentControl Content="{Binding Preview.TotalDelta}" ContentTemplate="{StaticResource PreviewDeltaTemplate}" />
                <ContentControl Content="{Binding Preview.CriticalDelta}" ContentTemplate="{StaticResource PreviewDeltaTemplate}" />
                <ContentControl Content="{Binding Preview.WarningDelta}" ContentTemplate="{StaticResource PreviewDeltaTemplate}" />
                <ContentControl Content="{Binding Preview.InfoDelta}" ContentTemplate="{StaticResource PreviewDeltaTemplate}" />
              </WrapPanel>

              <!-- Per-rule-class deltas: only changed classes (e.g. "nesting +2 · naming-gg -1").
                   Hidden when the edited ruleset matches the default per class (empty list). -->
              <WrapPanel Orientation="Horizontal"
                         IsVisible="{Binding Preview.RuleClassDeltas.Count}">
                <TextBlock Text="by rule:" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ItemsControl ItemsSource="{Binding Preview.RuleClassDeltas}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settings:PreviewDelta">
                      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource PreviewDeltaTemplate}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- Demo preview unavailable (rare): the embedded demo dataset could not be loaded, so
               no preview can be shown. The editor stays fully usable — the preview is an affordance,
               not a gate. -->
          <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                  IsVisible="{Binding PreviewUnavailable}"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                  CornerRadius="4" Padding="10,6">
            <TextBlock Text="Demo preview unavailable (the built-in demo directory could not be loaded)."
                       Opacity="0.7" TextWrapping="Wrap" />
          </Border>

          <!-- Editor surface + line-number gutter. The gutter (a single right-aligned
               monospace TextBlock numbered 1..N via LineNumberGutterConverter) and the editor
               TextBox share ONE outer ScrollViewer, so they scroll-sync as a single surface
               (no AvaloniaEdit, no new dependency). Both are monospace at the same FontSize so
               rows align. The TextBox suppresses its own scrollbars (the outer scroller drives).
               Contrast: the TextBox uses the Fluent default TextControl foreground/background
               pairing (the framework's WCAG-AA editor surface) — mono ink clears 4.5:1 in both
               theme variants on the input surface. -->
          <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                  CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
              <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
                        Padding="8,7,8,7">
                  <TextBlock Text="{Binding RawEditorText, Converter={x:Static views:LineNumberGutterConverter.ToLineNumbers}}"
                             FontFamily="{StaticResource FontFamilyMono}" FontSize="13"
                             TextAlignment="Right"
                             Foreground="{DynamicResource SecondaryForegroundBrush}" />
                </Border>
                <TextBox Grid.Column="1" Name="RawEditor"
                         Text="{Binding RawEditorText}"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         FontFamily="{StaticResource FontFamilyMono}" FontSize="13"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled" />
              </Grid>
            </ScrollViewer>
          </Border>

        </DockPanel>
      </TabItem>

    </TabControl>

  </DockPanel>

</Window>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Design tokens (#91): the chrome FOUNDATION the type scale + #92/#93 consume.
       Structural-neutral only — translucent ink over the page surface (the existing
       #…808080 separator language), NEVER a palette color (palette tone lives in
       the graph bundle / converters, not here).

       ADR-026 D1/D3 (WP1a): the surface/line/secondary-text/page roles are now
       theme-resolved via ThemeDictionaries (FluentTheme flips its own control
       defaults per variant in parallel). Dark values are byte-identical to the
       shipped palette so every ADR-021 WCAG ratio holds; the light values are
       Frame 4's re-derived translucent-BLACK-over-light counterparts. The graph
       CANVAS stays dark in WP1a (WP1b re-tones it). -->

  <ResourceDictionary.ThemeDictionaries>

    <!-- Dark (shipped values, UNCHANGED) -->
    <ResourceDictionary x:Key="Dark">
      <!-- Page/window background — the dark void (BrandTokens.PageBackgroundHex). -->
      <SolidColorBrush x:Key="PageBackgroundBrush" Color="#1b1f27" />
      <!-- Card chrome: translucent white over the dark void. -->
      <SolidColorBrush x:Key="CardBackgroundBrush" Color="#14FFFFFF" />
      <SolidColorBrush x:Key="CardBorderBrush" Color="#22FFFFFF" />
      <!-- Secondary-neutral foreground: solid white at the card-chrome family. -->
      <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#B0B5BD" />
      <!-- Ghost-button pointer-over wash (App.axaml). -->
      <SolidColorBrush x:Key="GhostHoverBrush" Color="#14FFFFFF" />

      <!-- WP1 active filter-chip (selected) surface + ink. OPAQUE (not the translucent card tint —
           that composite dropped the active count to 4.44:1 in light; WCAG 1.4.3). The raised dark
           grey reads as "selected" beside the 2px border; the near-white ink clears 4.5:1 with wide
           headroom (10.39:1) for BOTH the chip label and the count. -->
      <SolidColorBrush x:Key="ChipActiveBackgroundBrush" Color="#343A44" />
      <SolidColorBrush x:Key="ChipActiveForegroundBrush" Color="#F2F4F7" />

      <!-- ADR-026 D6 (WP2): the brand-purple accent. Decorative accent (DEMO badge text /
           focus rings) is the lighter Frame-1 hue; the primary-button FILL is the deeper
           accent-2 whose WHITE text clears 4.5:1 across rest/hover/pressed (mirrors
           BrandTokens.Accent* — values + ratios documented there + ADR-026 D6). -->
      <SolidColorBrush x:Key="AccentBrush" Color="#8B7BFF" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="#298B7BFF" />
      <SolidColorBrush x:Key="AccentLineBrush" Color="#808B7BFF" />
      <SolidColorBrush x:Key="AccentFillBrush" Color="#6B5BDF" />
      <SolidColorBrush x:Key="AccentFillHoverBrush" Color="#5F4FD0" />
      <SolidColorBrush x:Key="AccentFillPressedBrush" Color="#5B4BC8" />
      <!-- WP3 (#152): accessible accent INK for the promoted Audit button's outline
           label + glyph. The decorative AccentBrush #8B7BFF FAILS as text (3.96:1 on the
           card surface); this lightened accent reads 6.93:1 on the page and 5.48:1 on the
           card composite — clears 4.5:1 on both. Value = the proven accent-ink hue (mirrors
           BrandTokens.DemoBadgeTextHex, the ADR-021 ToTextBrush-deepened accent).
           ADR-033: the keyboard-focus-visible FocusAdorner ring (App.axaml) strokes its 2px Border in
           this SAME ink (the >=3:1 non-text accent), DynamicResource-bound so it re-resolves per theme. -->
      <SolidColorBrush x:Key="AccentTextBrush" Color="#A99BFF" />
      <!-- DEMO badge ink: deepened/lightened off the raw accent to clear 4.5:1 on the soft
           pill (the label is readable text — 1.4.3 applies; ADR-021 ToTextBrush precedent).
           Dark pill is dark ⇒ a LIGHTER purple (5.51:1 on the blended pill). -->
      <SolidColorBrush x:Key="DemoBadgeTextBrush" Color="#A99BFF" />
      <!-- Always-on Read-only pill (Frame-1 green-soft pill + green ink @5.93:1 on the pill). -->
      <SolidColorBrush x:Key="ReadOnlyPillTextBrush" Color="#46C98A" />
      <SolidColorBrush x:Key="ReadOnlyPillBackgroundBrush" Color="#2646C98A" />

      <!-- WP6a: validation-error MESSAGE ink for the settings bands. The #22D13438 band tint
           composites over the dark page to #332229; the raw error red #D13438 reads only 3.04:1 on
           it. A lighter red (#FF8A8E, BrandTokens.ValidationErrorTextHex) reads 6.62:1 — keeps the
           error semantic, clears 1.4.3. (Mirrors BrandTokens; reviewer enforces parity.) -->
      <SolidColorBrush x:Key="ValidationErrorTextBrush" Color="#FF8A8E" />

      <!-- WP6b: the demo-preview "more findings than default" caution ink (= BrandTokens
           .PreviewCautionTextHex; reviewer enforces parity). Sits on the preview card
           (CardBackgroundBrush #14FFFFFF over the dark page ⇒ ~#2C2F37). The severity amber
           #F7A30B reads ~6.5:1 there; kept as the dark caution ink (color is a redundant cue — the
           signed text always carries the meaning). -->
      <SolidColorBrush x:Key="PreviewCautionTextBrush" Color="#F7A30B" />
    </ResourceDictionary>

    <!-- Light (ADR-026 D3, Frame 4: re-derived, translucent BLACK over the light page) -->
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="PageBackgroundBrush" Color="#ECEEF1" />
      <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0A000000" />
      <SolidColorBrush x:Key="CardBorderBrush" Color="#1A000000" />
      <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#5A636E" />
      <SolidColorBrush x:Key="GhostHoverBrush" Color="#0D000000" />

      <!-- WP1 active filter-chip (selected) surface + ink (light): an opaque light grey beside the
           2px border; near-black ink clears 4.5:1 with headroom (11.78:1) for label AND count. -->
      <SolidColorBrush x:Key="ChipActiveBackgroundBrush" Color="#DDE0E5" />
      <SolidColorBrush x:Key="ChipActiveForegroundBrush" Color="#1F242C" />

      <!-- ADR-026 D6 (WP2): Frame-4 brand purple (decorative + accessible fill). -->
      <SolidColorBrush x:Key="AccentBrush" Color="#6A5CFF" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="#1F6A5CFF" />
      <SolidColorBrush x:Key="AccentLineBrush" Color="#806A5CFF" />
      <SolidColorBrush x:Key="AccentFillBrush" Color="#5547E6" />
      <SolidColorBrush x:Key="AccentFillHoverBrush" Color="#4A3CC8" />
      <SolidColorBrush x:Key="AccentFillPressedBrush" Color="#4537C0" />
      <!-- WP3 (#152): light-theme accessible accent INK for the Audit button (see dark note).
           Deepened purple reads 6.52:1 on the page and 6.00:1 on the card composite — clears
           4.5:1 on both. Mirrors BrandTokens.DemoBadgeTextLightHex. ADR-033: the keyboard-focus-visible
           FocusAdorner ring strokes in this same ink (see the dark note above). -->
      <SolidColorBrush x:Key="AccentTextBrush" Color="#4A3CC8" />
      <!-- DEMO badge ink: light pill is light ⇒ a DARKER purple (5.62:1 on the blended pill). -->
      <SolidColorBrush x:Key="DemoBadgeTextBrush" Color="#4A3CC8" />
      <!-- Read-only ink deepened to a forest green: the Frame #1F9D57 fails at 2.65:1 on the
           blended light pill; #0B6B36 clears it at 5.03:1 (and 5.70:1 on the raw page). -->
      <SolidColorBrush x:Key="ReadOnlyPillTextBrush" Color="#0B6B36" />
      <SolidColorBrush x:Key="ReadOnlyPillBackgroundBrush" Color="#1F1F9D57" />

      <!-- WP6a: the #22D13438 band tint composites over the light page to a pale pink #E8D5D8; the
           raw error red reads only 3.51:1. A deeper red (#A4262C, BrandTokens.ValidationErrorTextLightHex)
           reads 5.17:1 — still unmistakably the error red, clears 1.4.3. -->
      <SolidColorBrush x:Key="ValidationErrorTextBrush" Color="#A4262C" />

      <!-- WP6b: the light-theme caution ink (= BrandTokens.PreviewCautionTextLightHex; reviewer
           enforces parity) on the light preview card. The card surface renders
           marginally lighter than the flat estimate (≈#E3E5E8), where #8A5A00 measured only 4.65:1
           (a pass, but at the floor); deepened to #7A4F00 ⇒ ~5.4:1 for headroom — still unmistakably
           a caution amber, color redundant to the always-shown signed delta text. -->
      <SolidColorBrush x:Key="PreviewCautionTextBrush" Color="#7A4F00" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- Theme-invariant tokens (spacing rhythm, corner radius, mono font stack) at the
       dictionary root — these do not change by variant. -->

  <!-- Spacing rhythm (a single 4px scale). -->
  <x:Double x:Key="SpaceXs">4</x:Double>
  <x:Double x:Key="SpaceSm">8</x:Double>
  <x:Double x:Key="SpaceMd">12</x:Double>
  <x:Double x:Key="SpaceLg">16</x:Double>
  <x:Double x:Key="SpaceXl">24</x:Double>

  <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>

  <!-- Tabular monospace name-stack for DNs / raw directory strings — no bundled
       asset; mirrors the graph bundle's web/index.html legend font stack. -->
  <FontFamily x:Key="FontFamilyMono">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>

  <!-- Soft bottom-fade OpacityMask (#92) for internally-scrolling findings lists: a render-time
       composite so a finding clipped at the scroll fold reads as scrollable, not broken. Pure
       alpha (opaque → transparent), so it is theme-independent and lives with the invariant
       tokens. Render-only — it does NOT alter row measurement/realization; apply it to the
       scrolling ListBox ONLY, never a list's header/chip strip. -->
  <LinearGradientBrush x:Key="ListBottomFadeMask" StartPoint="0%,0%" EndPoint="0%,100%">
    <GradientStop Color="#FFFFFFFF" Offset="0.0" />
    <GradientStop Color="#FFFFFFFF" Offset="0.92" />
    <GradientStop Color="#00FFFFFF" Offset="1.0" />
  </LinearGradientBrush>

</ResourceDictionary>
